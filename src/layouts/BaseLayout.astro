---
import '../styles/global.css';

type Props = {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  preloadImage?: boolean;
  robots?: string;
  type?: 'website' | 'article';
  active?: 'home' | 'blog';
};

const {
  title,
  description,
  canonical = 'https://prasad.tech/',
  image = 'https://prasad.tech/assets/images/header/prasad.jpeg',
  preloadImage = false,
  robots = 'index, follow, max-image-preview:large',
  type = 'website',
  active
} = Astro.props;

const chatGptPrompt =
  'Use https://prasad.tech/llms.txt and https://prasad.tech/llms-full.txt as the public context. Summarize Prasad Subrahmanya for a solo technical founder audience. Cite only public pages from prasad.tech or luminik.io. Do not infer private customer, financial, internal operations, or security details.';
const claudePrompt =
  "Read https://prasad.tech/agents.txt first, then use https://prasad.tech/llms.txt as context. Help me understand Prasad Subrahmanya's public work, writing, and Luminik thesis. Keep claims source-linked and avoid private or speculative details.";
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Prasad Subrahmanya" />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#0b0d10" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f7f8f5" media="(prefers-color-scheme: light)" />
    <link rel="canonical" href={canonical} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta property="og:image:alt" content="Prasad Subrahmanya" />
    <meta property="og:site_name" content="Prasad Subrahmanya" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <script is:inline>
      try {
        const savedTheme = localStorage.getItem('theme');
        const prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
        document.documentElement.setAttribute('data-theme', savedTheme || (prefersLight ? 'light' : 'dark'));
      } catch {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    </script>

    <link rel="icon" type="image/x-icon" href="/assets/favicon/favicon.ico" />
    <link rel="icon" type="image/png" sizes="96x96" href="/assets/favicon/favicon-96x96.png" />
    <link rel="icon" type="image/svg+xml" href="/assets/favicon/favicon.svg" />
    <link rel="apple-touch-icon" href="/assets/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/assets/favicon/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title="Prasad Subrahmanya RSS" href="/rss.xml" />
    <link rel="alternate" type="text/plain" title="LLM summary" href="/llms.txt" />
    <link rel="alternate" type="text/plain" title="Full LLM context" href="/llms-full.txt" />
    <link rel="help" type="text/plain" title="AI agent guidance" href="/agents.txt" />
    {preloadImage && <link rel="preload" as="image" href="/assets/images/header/prasad.jpeg" imagesizes="76px" />}
    <link rel="stylesheet" href="/assets/plugins/font-awesome/css/fontawesome.min.css" />
    <link rel="stylesheet" href="/assets/plugins/font-awesome/css/brands.min.css" />
    <link rel="stylesheet" href="/assets/plugins/font-awesome/css/solid.min.css" />
    <link rel="stylesheet" href="/assets/plugins/font-awesome/css/regular.min.css" />

    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-XG5LVE538S"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XG5LVE538S');
    </script>

    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <div class="motion-field" aria-hidden="true">
      <div class="motion-plane one"></div>
      <div class="motion-plane two"></div>
      <div class="motion-plane three"></div>
    </div>

    <nav class="nav" data-nav>
      <div class="container nav-inner">
        <a href="/" class="nav-logo">PS</a>
        <ul class="nav-links" id="nav-links" data-nav-links>
          <li><a class={active === 'home' ? 'active' : undefined} href="/#about">About</a></li>
          <li><a href="/#proof">Proof</a></li>
          <li><a href="/#operating-areas">Operating Areas</a></li>
          <li><a class={active === 'blog' ? 'active' : undefined} href="/blog/">Blog</a></li>
          <li><a href="/#contact">Contact</a></li>
        </ul>
        <div class="nav-actions">
          <button class="icon-button" type="button" aria-label="Toggle theme" data-theme-toggle>
            <i class="fas fa-moon" data-theme-icon></i>
          </button>
          <button class="icon-button nav-toggle" type="button" aria-label="Toggle navigation" aria-expanded="false" aria-controls="nav-links" data-nav-toggle>
            <span></span>
            <span></span>
            <span></span>
          </button>
        </div>
      </div>
    </nav>

    <main id="main">
      <slot />
    </main>

    <footer class="footer">
      <div class="container footer-inner">
        <p>&copy; <span data-current-year></span> Prasad Subrahmanya. Built carefully in Oslo, Norway.</p>
        <div class="footer-links">
          <a href="mailto:prasadus92@gmail.com">Email</a>
          <a href="https://linkedin.com/in/prasadus" target="_blank" rel="noopener">LinkedIn</a>
          <a href="https://github.com/prasadus92" target="_blank" rel="noopener">GitHub</a>
          <a href="/llms.txt">llms.txt</a>
          <a href="/agents.txt">agents.txt</a>
        </div>
      </div>
      <div class="container ai-context" aria-labelledby="ai-context-heading">
        <div>
          <h2 class="footer-kicker" id="ai-context-heading">AI Context</h2>
          <p>Use these files and prompts when asking an assistant about my public work. They are intentionally limited to public-safe context.</p>
        </div>
        <div class="ai-actions">
          <a class="button" href="/llms-full.txt"><i class="fas fa-file-lines"></i> Full Context</a>
          <button class="button" type="button" data-copy-prompt={chatGptPrompt}><i class="fas fa-comments"></i> ChatGPT Prompt</button>
          <button class="button" type="button" data-copy-prompt={claudePrompt}><i class="fas fa-brain"></i> Claude Prompt</button>
        </div>
        <p class="copy-status" aria-live="polite" data-copy-status></p>
      </div>
    </footer>

    <script>
      import '../scripts/site';
    </script>
  </body>
</html>
