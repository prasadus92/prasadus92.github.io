---
import "../styles/v2.css";
import Analytics from "../components/Analytics.astro";
import PostHog from "../components/PostHog.astro";
import CookieConsentV2 from "../components/v2/CookieConsentV2.astro";
const { title = "Prasad Subrahmanya", description = "" } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="alternate" type="text/plain" title="llms.txt" href="/llms.txt" />
  <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
  <link href="https://api.fontshare.com/v2/css?f[]=clash-display@400,500,600,700&f[]=general-sans@400,500,600,700&display=swap" rel="stylesheet" />
  <!-- Analytics (consent-gated; shares consent + variant with v1) -->
  <Analytics />
  <PostHog />
</head>
<body>
  <slot />
  <CookieConsentV2 />
</body>
</html>
