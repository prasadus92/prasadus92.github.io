---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Privacy Note';
const description = 'A concise privacy and cookie note for prasad.tech, including analytics consent, essential preferences, and contact details.';
---

<BaseLayout
  title={title}
  description={description}
  canonical="https://prasad.tech/privacy/"
  image="/og/prasad-og.png"
  imageAlt="Prasad Subrahmanya | privacy note for prasad.tech"
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Privacy', url: '/privacy/' }
  ]}
>
  <section class="section legal-page">
    <div class="container legal-shell">
      <div class="section-header">
        <div class="eyebrow reveal">Privacy</div>
        <h1 class="reveal">Privacy note for prasad.tech</h1>
        <p class="lead reveal">
          This site is a public portfolio and writing archive. I keep measurement simple and only use analytics after you allow it.
        </p>
      </div>

      <div class="legal-grid">
        <section class="card reveal">
          <h2>What the site collects</h2>
          <p>
            If you accept analytics, Google Analytics may collect page views, device and browser information, approximate geography, referrers, and interaction signals. IP anonymization is enabled.
          </p>
          <p>
            Essential preferences, such as theme choice and cookie preference, are stored locally in your browser.
          </p>
        </section>

        <section class="card reveal">
          <h2>Analytics consent</h2>
          <p>
            Analytics is off until you choose to accept it. Rejecting analytics keeps Google Analytics from loading on this site.
          </p>
          <p>
            Use the footer's Cookie settings control to reopen the banner and change your choice.
          </p>
        </section>

        <section class="card reveal">
          <h2>Third-party embeds</h2>
          <p>
            The intro-chat page embeds Cal.com so you can book a time. Cal.com runs inside its own iframe and may process booking details when you interact with it.
          </p>
        </section>

        <section class="card reveal">
          <h2>Contact</h2>
          <p>
            For privacy questions or deletion requests, email <a href="mailto:prasadus92@gmail.com">prasadus92@gmail.com</a>.
          </p>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>
