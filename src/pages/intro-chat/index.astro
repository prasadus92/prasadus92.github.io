---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CalEmbed from '../../components/CalEmbed.astro';
import Icon from '../../components/Icon.astro';

const title = 'Intro Chat';
const description = 'Book an intro chat with Prasad Subrahmanya about Luminik, event pipeline, solo-builder systems, founder-led sales, or zero-to-one B2B product work.';
const directBookingUrl = 'https://cal.com/meet-prasad/intro-chat';
---

<BaseLayout
  title={title}
  description={description}
  canonical="https://prasad.tech/intro-chat/"
  image="/og/prasad-og.png"
  imageAlt="Prasad Subrahmanya | Founder of Luminik. Field notes for solo technical builders."
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Intro Chat', url: '/intro-chat/' }
  ]}
>
  <section class="section booking-page">
    <div class="container booking-page-inner">
      <div class="section-header center booking-intro">
        <div class="eyebrow reveal">Intro chat</div>
        <h1 class="reveal">Book a focused intro chat.</h1>
        <p class="lead reveal">
          Twenty minutes to compare notes on Luminik, event pipeline, solo-builder systems, founder-led sales, or zero-to-one B2B product work. A specific problem makes the conversation useful.
        </p>
        <div class="hero-actions reveal">
          <a class="button" href="mailto:prasadus92@gmail.com"><Icon name="envelope" size={16} /> Email context</a>
          <a class="button" href={directBookingUrl} target="_blank" rel="noopener"><Icon name="arrow-up-right" size={16} /> Open Cal.com</a>
        </div>
      </div>

      <div class="booking-shell reveal" id="book">
        <div class="booking-panel-header">
          <div>
            <div class="eyebrow">Calendar</div>
            <h2>Pick a time that works</h2>
          </div>
          <p>Timezone adjusts automatically.</p>
        </div>
        <CalEmbed />
        <p class="booking-fallback">
          Open the <a href={directBookingUrl} target="_blank" rel="noopener">booking page directly</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
