---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found | Prasad Subrahmanya" description="The page you requested could not be found." canonical="https://prasad.tech/404.html">
  <section class="hero">
    <div class="container">
      <div class="eyebrow reveal">404</div>
      <h1 class="reveal">This page is not here.</h1>
      <p class="lead reveal" style="max-width: 680px;">
        The writing moved into a cleaner Astro structure. The blog index is the best place to restart.
      </p>
      <div class="hero-actions reveal">
        <a class="button primary" href="/blog/">Go to Blog</a>
        <a class="button" href="/">Go Home</a>
      </div>
    </div>
  </section>
</BaseLayout>
