---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import { formatMonth, posts } from '../../lib/posts';

const title = 'Notes on product, sales, and agent work';
const description = 'Essays from building Luminik and earlier products: B2B product engineering, founder-led sales, agent workflows, event pipeline systems, and zero-to-one work.';
const keywords = [
  'technical founder writing',
  'B2B product engineering',
  'founder-led sales',
  'agent workflows',
  'event pipeline systems',
  'zero-to-one product',
  'Luminik',
  'Alfred OS'
];
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Blog', url: '/blog/' }
];

const paths = [
  {
    title: 'Solo builder OS',
    body: 'Alfred, CLAUDE.md files, isolated branches, approval rules, and the recurring checks I run while building Luminik.',
    href: '/blog/alfred-solo-founder-operating-system.html'
  },
  {
    title: 'Founder-led sales',
    body: 'Sales starts by understanding how the buyer does the work today. Useful before hiring a sales motion.',
    href: '/blog/selling-before-building.html'
  },
  {
    title: 'Event pipeline',
    body: 'How event ROI breaks across handoffs, and why the answer starts with one event operating record.',
    href: '/blog/event-marketing-roi.html'
  },
  {
    title: 'Zero to one',
    body: 'Mainteny, Aura, SnowOptix, and the product decisions that changed what I built next.',
    href: '/blog/mvp-three-months.html'
  }
];

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Prasad Subrahmanya Blog',
  description,
  url: 'https://prasad.tech/blog/',
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: posts.map((post, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: `https://prasad.tech${post.url}`,
      name: post.title
    }))
  }
};
---

<BaseLayout
  title={title}
  description={description}
  canonical="https://prasad.tech/blog/"
  active="blog"
  image="/og/prasad-og.png"
  imageAlt="Prasad Subrahmanya, notes on product, sales, and agent work"
  keywords={keywords}
  breadcrumbs={breadcrumbs}
>
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />

  <section class="blog-hero">
    <div class="container">
      <div class="eyebrow reveal">Blog</div>
      <h1 class="reveal">Notes on product, sales, and agent work</h1>
      <p class="lead reveal" style="max-width: 760px; margin: 0 auto;">
        Notes from building Luminik and earlier products: product decisions, sales calls, agent workflows, event pipeline systems, and zero-to-one work.
      </p>
    </div>
  </section>

  <section class="section tight">
    <div class="container">
      <article class="featured-post card reveal">
        <div>
          <span class="blog-category">{posts[0].category}</span>
          <h2>{posts[0].title}</h2>
          <p>{posts[0].description}</p>
          <div class="hero-actions">
            <a class="button primary" href={posts[0].url}>Start here <Icon name="arrow-right" size={16} /></a>
          </div>
        </div>
        <div class="featured-diagram" aria-label="Alfred work preview">
          <div class="featured-diagram-row">
            <strong>Context</strong>
            <span>CLAUDE.md files, specs, voice rules, and public positioning.</span>
          </div>
          <div class="featured-diagram-row">
            <strong>Work</strong>
            <span>Digests with links, pull requests, draft copy, and drift checks.</span>
          </div>
          <div class="featured-diagram-row">
            <strong>Gate</strong>
            <span>Human approval before publish, merge, send, or deploy.</span>
          </div>
        </div>
      </article>

      <div class="blog-grid">
        {posts.map((post) => (
          <a class="blog-card card interactive reveal" href={post.url}>
            <div class="blog-card-content">
              <span class="blog-category">{post.category}</span>
              <h3>{post.title}</h3>
              <p>{post.description}</p>
              <div class="blog-meta">
                <span><Icon name="calendar" size={14} /> {formatMonth(post.date)}</span>
                <span><Icon name="clock" size={14} /> {post.readTime}</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="path-grid blog-path-grid" style="margin-top: 44px;">
        {paths.map((path) => (
          <a class="path-card card interactive reveal" href={path.href} style="color: inherit; text-decoration: none;">
            <h3>{path.title}</h3>
            <p>{path.body}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
