---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import Lattice from '../../components/Lattice.astro';
import { site } from '../../data/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Two clusters, by slug membership (robust to category strings). Engineering
// shows first. Anything not listed in either set falls under engineering.
const engineeringSlugs = new Set([
  'verifier-design-agent-rl',
  'idempotent-ingestion',
  'multi-model-proxy',
  'cut-coding-agent-token-bill',
  'durable-by-design',
  'loops-harnesses-memory',
  'deploying-a-customer-support-ai-agent-to-production',
  'hotel-kpi-elt-pipeline',
  'snowflake-cost-optimization',
]);
const companySlugs = new Set([
  'zero-to-one-bain',
  'raising-seed-round',
  'technical-founder-sales',
  'mvp-three-months',
  'event-marketing-roi',
  'too-early-teen-banking-startup',
]);

// posts is already newest-first, so each cluster preserves that order.
const companyPosts = posts.filter((p) => companySlugs.has(p.id));
const engineeringPosts = posts.filter((p) => !companySlugs.has(p.id));

const slug = (s: string) =>
  s
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');

const clusters = [
  { title: 'AI-native engineering', posts: engineeringPosts },
  { title: 'Building companies', posts: companyPosts },
]
  .filter((c) => c.posts.length > 0)
  .map((c) => ({ ...c, key: slug(c.title) }));

const totalPosts = clusters.reduce((n, c) => n + c.posts.length, 0);

// Suppress an unused-variable lint while keeping the explicit slug set for clarity.
void engineeringSlugs;
---

<BaseLayout
  title={`Writing - ${site.name}`}
  description="Hands-on writing on AI-native engineering, evals, durable workflows, and building companies."
  image="/og/blog.png"
>
  <section class="section blog-index">
    <div class="container">
      <header class="blog-hero">
        <p class="eyebrow reveal">Writing</p>
        <h1 class="reveal reveal-d1">
          Field <span class="grad-text">notes</span>.
        </h1>
        <p class="muted reveal reveal-d2">
          Hands-on writing on AI-native engineering, evals, durable workflows, and the operator side
          of building companies. From what I have shipped.
        </p>
      </header>

      {
        clusters.length > 1 && (
          <div class="blog-filters reveal" role="group" aria-label="Filter writing by topic">
            <button type="button" class="filter-chip" data-filter="all" aria-pressed="true">
              All <span class="chip-count">{totalPosts}</span>
            </button>
            {clusters.map((cluster) => (
              <button
                type="button"
                class="filter-chip"
                data-filter={cluster.key}
                aria-pressed="false"
              >
                {cluster.title} <span class="chip-count">{cluster.posts.length}</span>
              </button>
            ))}
          </div>
        )
      }

      <div class="blog-divider reveal" aria-hidden="true">
        <Lattice variant="divider" accent />
      </div>

      <div data-blog-list>
        {
          clusters.map((cluster, ci) => (
            <section class="blog-cluster" data-cluster={cluster.key}>
              <h2 class="cluster-title reveal">{cluster.title}</h2>
              <div class="blog-grid">
                {cluster.posts.map((p, i) => (
                  <BlogCard
                    slug={p.id}
                    title={p.data.title}
                    description={p.data.description}
                    pubDate={p.data.pubDate}
                    category={p.data.category}
                    readingTime={p.data.readingTime}
                    featured={ci === 0 && i === 0}
                    delay={(i % 3) + 1}
                  />
                ))}
              </div>
            </section>
          ))
        }
        <p class="blog-empty" data-blog-empty hidden>Nothing here yet under this topic.</p>
      </div>
    </div>
  </section>

  <script>
    const chips = Array.from(
      document.querySelectorAll<HTMLButtonElement>('.filter-chip')
    );
    const sections = Array.from(
      document.querySelectorAll<HTMLElement>('[data-cluster]')
    );
    const empty = document.querySelector<HTMLElement>('[data-blog-empty]');
    if (chips.length) {
      const apply = (filter: string) => {
        let visible = 0;
        sections.forEach((s) => {
          const show = filter === 'all' || s.dataset.cluster === filter;
          s.hidden = !show;
          if (show) visible++;
        });
        if (empty) empty.hidden = visible !== 0;
        chips.forEach((c) =>
          c.setAttribute('aria-pressed', String(c.dataset.filter === filter))
        );
      };
      chips.forEach((c) =>
        c.addEventListener('click', () => apply(c.dataset.filter || 'all'))
      );
    }
  </script>
</BaseLayout>

<style>
  .blog-index {
    padding-top: clamp(120px, 15vh, 170px);
  }
  .blog-hero {
    max-width: 62ch;
    margin-bottom: clamp(40px, 5vw, 64px);
  }
  .blog-hero h1 {
    margin-top: 14px;
    font-size: clamp(2.2rem, 1.5rem + 3vw, 3.6rem);
  }
  .blog-hero p {
    margin-top: 20px;
    font-size: var(--fs-lead);
    line-height: 1.6;
  }
  .blog-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: clamp(36px, 4.5vw, 56px);
  }
  .filter-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 15px;
    border-radius: var(--r-pill);
    font-family: var(--font-display);
    font-size: var(--fs-sm);
    font-weight: 500;
    color: var(--text-secondary);
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    transition: color var(--dur-1) var(--ease-out), border-color var(--dur-2) var(--ease-out),
      background var(--dur-2) var(--ease-out);
  }
  .filter-chip:hover {
    color: var(--ink);
    border-color: var(--glass-border-strong);
    background: var(--glass-bg-strong);
  }
  .filter-chip[aria-pressed='true'] {
    color: var(--accent-ink);
    background: var(--accent);
    border-color: var(--accent);
  }
  .filter-chip .chip-count {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    opacity: 0.75;
  }
  /* thin cultural-geometry band separating the hero from the archive; the
     Lattice already fades at both horizontal edges so it reads as texture */
  .blog-divider {
    position: relative;
    height: 60px;
    margin-bottom: clamp(28px, 4vw, 48px);
  }
  .blog-empty {
    color: var(--text-tertiary);
    font-size: var(--fs-lead);
    padding: clamp(32px, 5vw, 56px) 0;
    text-align: center;
  }
  .blog-cluster {
    margin-bottom: clamp(48px, 6vw, 88px);
  }
  /* When a cluster is hidden by the filter, drop its trailing margin. */
  .blog-cluster[hidden] {
    display: none;
  }
  .blog-cluster:last-child {
    margin-bottom: 0;
  }
  .cluster-title {
    font-size: clamp(1.3rem, 1.1rem + 1vw, 1.7rem);
    letter-spacing: var(--tracking-tight);
    margin-bottom: clamp(20px, 2.4vw, 28px);
    padding-bottom: 14px;
    border-bottom: 1px solid var(--glass-border);
  }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(14px, 1.6vw, 20px);
  }
  @media (max-width: 760px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
