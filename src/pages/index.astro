---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import ProofStrip from '../components/islands/ProofStrip';
import type { ProofPoint } from '../components/islands/ProofStrip';
import { featuredPosts, formatMonth } from '../lib/posts';

const proofPoints: ProofPoint[] = [
  {
    label: 'Aura at Bain',
    value: '$3.6M ARR',
    numericValue: 3.6,
    prefix: '$',
    suffix: 'M ARR',
    caption: 'Built a PE due diligence platform inside Bain and took it from concept to revenue in 18 months.'
  },
  {
    label: 'Mainteny',
    value: '$2.7M raised',
    numericValue: 2.7,
    prefix: '$',
    suffix: 'M seed',
    caption: 'Co-founded Mainteny, built the initial product, worked directly with early customers, and helped build the product and engineering team.'
  },
  {
    label: 'Solo builder',
    value: '12+ years',
    numericValue: 12,
    suffix: '+ years',
    caption: 'Engineering, product, and founder-led GTM across 4 companies. Now building Luminik.'
  }
];

const title = 'Prasad Subrahmanya';
const description = 'I build Luminik hands-on and write about B2B product work, founder-led sales, agent workflows, and building teams from the first version.';
const keywords = [
  'Prasad Subrahmanya',
  'Luminik founder',
  'builder and operator',
  'B2B product engineering',
  'founder-led sales',
  'engineering leadership',
  'agent workflows',
  'event pipeline platform'
];
---

<BaseLayout
  title={title}
  description={description}
  canonical="https://prasad.tech/"
  active="home"
  preloadImage
  image="/og/prasad-og.png"
  imageAlt="Prasad Subrahmanya, builder and operator at Luminik"
  keywords={keywords}
>

  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <div class="eyebrow reveal">Builder and operator</div>
        <h1 class="reveal">I build B2B products from customer work.</h1>
        <p class="lead reveal">
          I'm Prasad Subrahmanya. I build <a href="https://www.luminik.io" target="_blank" rel="noopener">Luminik</a>, an event pipeline platform for B2B teams. I sell before I build, work alongside customers, and turn repeated workflows into product.
        </p>
        <div class="hero-actions reveal">
          <a href="/blog/" class="button primary"><Icon name="book-open" size={16} /> Read the blog</a>
          <a href="https://www.luminik.io" target="_blank" rel="noopener" class="text-link">Visit Luminik <Icon name="arrow-up-right" size={15} /></a>
        </div>
      </div>

      <div class="hero-portrait-card card reveal">
        <div class="hero-portrait-frame">
          <img src="/assets/images/header/prasad.jpeg" width="800" height="800" alt="Prasad Subrahmanya" decoding="async" fetchpriority="high" />
        </div>
        <div class="hero-current">
          <div class="eyebrow">Current focus</div>
          <h2>Luminik and Alfred OS</h2>
          <p>I am building Luminik and maintaining Alfred OS, an open-source runner for agent work in isolated git worktrees.</p>
        </div>
        <div class="proof-list">
          <div class="proof-item">
            <div class="proof-number">01</div>
            <p>Luminik helps B2B teams source, enrich, sequence, capture, and attribute event-sourced pipeline.</p>
          </div>
          <div class="proof-item">
            <div class="proof-number">02</div>
            <p><a href="https://github.com/luminik-io/alfred-os" target="_blank" rel="noopener">Alfred OS</a> runs Claude Code and Codex tasks in separate git worktrees.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section tight" id="track-record" aria-labelledby="track-record-heading">
    <div class="container">
      <div class="section-header">
        <div class="eyebrow reveal">Track record</div>
        <h2 class="reveal" id="track-record-heading">A few outcomes from shipped work</h2>
        <p class="lead reveal">
          I have built revenue-generating software inside Bain, co-founded a venture-backed company, and led the hands-on product work and team-building that followed.
        </p>
      </div>
      <ProofStrip points={proofPoints} client:visible />
    </div>
  </section>

  <section class="section" id="about">
    <div class="container two-column">
      <div class="section-header" style="margin-bottom: 0;">
        <div class="eyebrow reveal">About</div>
        <h2 class="reveal">How I usually build</h2>
      </div>
      <div>
        <p class="lead reveal">
          Good B2B software usually starts with work someone already owns. I want to know who is responsible for it, why it matters now, what they tried already, where the handoff breaks, and what would make the next decision easier. That usually means manual delivery first, a narrow first version, and sales calls that change the roadmap.
        </p>
        <p class="lead reveal">
          Right now I am building Luminik. Before that I built SnowOptix, Aura at Bain, and Mainteny. The setting changed each time. The work stayed similar: find demand in existing work, build the first useful version, sell through the workflow, and explain the tradeoffs plainly.
        </p>
      </div>
    </div>
  </section>

  <section class="section" id="operating-areas">
    <div class="container">
      <div class="section-header center">
        <div class="eyebrow reveal">Operating areas</div>
        <h2 class="reveal">What I build and write about</h2>
        <p class="lead reveal">Useful notes for technical founders who build, sell, and operate the first version themselves.</p>
      </div>

      <div class="path-grid">
        <div class="path-card card interactive reveal">
          <h3>Solo product engineering</h3>
          <p>Turn first-hand workflow knowledge into usable software, then build the team and standards around it.</p>
        </div>
        <div class="path-card card interactive reveal">
          <h3>Founder-led GTM</h3>
          <p>Look for the live project, the urgency, the options tried, and the gap that makes a team move.</p>
        </div>
        <div class="path-card card interactive reveal">
          <h3>AI-agent workflows</h3>
          <p>Use agents for scoped work: specs, repo rules, isolated branches, tests, and pull requests.</p>
        </div>
        <div class="path-card card interactive reveal">
          <h3>Event pipeline systems</h3>
          <p>The data model behind event ROI: sourcing, enrichment, sequencing, capture, and attribution as one record.</p>
        </div>
      </div>

      <div class="artifact-map" style="margin-top: 34px;">
        <div class="artifact-node card reveal">
          <span>01</span>
          <strong>Demand</strong>
          <p>Start with a project someone already owns and has to make visible.</p>
        </div>
        <div class="artifact-node card reveal">
          <span>02</span>
          <strong>Manual delivery</strong>
          <p>Do the work manually before deciding what the product should automate.</p>
        </div>
        <div class="artifact-node card reveal">
          <span>03</span>
          <strong>Narrow software</strong>
          <p>Automate the repeated steps. Keep ambiguous decisions with a person.</p>
        </div>
        <div class="artifact-node card reveal">
          <span>04</span>
          <strong>Agent workflow</strong>
          <p>Let agents draft, code, check, and summarize inside explicit boundaries.</p>
        </div>
        <div class="artifact-node card reveal">
          <span>05</span>
          <strong>Trust</strong>
          <p>Explain the tradeoffs clearly enough for customers, teammates, and investors.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="experience">
    <div class="container">
      <div class="section-header">
        <div class="eyebrow reveal">Experience</div>
        <h2 class="reveal">Where I have built and shipped</h2>
        <p class="lead reveal">Different settings, same job: understand the business, build the product, sell the early version, and keep decisions tied to customer evidence.</p>
      </div>

      <div class="experience-grid">
        <div class="experience-card card reveal">
          <div class="experience-top">
            <div>
              <p class="experience-company">Luminik</p>
              <h3>Founder</h3>
            </div>
            <span class="experience-date">Oct 2024 - Present</span>
          </div>
          <p>Building an event pipeline platform for B2B teams that need one record from source to attribution: source, enrich, sequence, capture, and attribute.</p>
          <div class="tag-row">
            <span class="tag">Event pipeline</span>
            <span class="tag">B2B GTM</span>
            <span class="tag">AI agents</span>
            <span class="tag">Founder-led sales</span>
          </div>
        </div>

        <div class="experience-card card reveal">
          <div class="experience-top">
            <div>
              <p class="experience-company">SnowOptix</p>
              <h3>Founder</h3>
            </div>
            <span class="experience-date">Jan 2024 - Oct 2024</span>
          </div>
          <p>A Snowflake cost optimization side project that entered Snowflake's Native App Accelerator with support from the startups team. The conversations validated the cost pain and pointed me toward events, where buyers had a live workflow and a clearer reason to move.</p>
          <div class="tag-row">
            <span class="tag">Snowflake</span>
            <span class="tag">Data engineering</span>
            <span class="tag">Customer discovery</span>
          </div>
        </div>

        <div class="experience-card card reveal">
          <div class="experience-top">
            <div>
              <p class="experience-company">Bain & Company</p>
              <h3>Venture CTO</h3>
            </div>
            <span class="experience-date">Nov 2022 - Dec 2023</span>
          </div>
          <p>Built and scaled Aura, a PE due diligence SaaS platform, from concept to $3.6M ARR in 18 months.</p>
          <div class="tag-row">
            <span class="tag">SaaS</span>
            <span class="tag">Due diligence</span>
            <span class="tag">Venture building</span>
          </div>
        </div>

        <div class="experience-card card reveal">
          <div class="experience-top">
            <div>
              <p class="experience-company">Mainteny</p>
              <h3>Co-founder and CTO</h3>
            </div>
            <span class="experience-date">Aug 2020 - Oct 2022</span>
          </div>
          <p>Built the initial product, worked directly with early customers, helped raise a $2.7M seed, and helped build the product and engineering team.</p>
          <div class="tag-row">
            <span class="tag">Field service</span>
            <span class="tag">Elevator maintenance</span>
            <span class="tag">First product</span>
            <span class="tag">Fundraising</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="blog">
    <div class="container">
      <div class="section-header center">
        <div class="eyebrow reveal">Writing</div>
        <h2 class="reveal">Notes from the work</h2>
        <p class="lead reveal">Essays on building, selling, AI-agent workflows, and the moment manual customer work becomes software.</p>
      </div>

      <div class="blog-grid">
        {featuredPosts.map((post) => (
          <a class="blog-card card interactive reveal" href={post.url}>
            <div class="blog-card-content">
              <span class="blog-category">{post.category}</span>
              <h3>{post.title}</h3>
              <p>{post.description}</p>
              <div class="blog-meta">
                <span><Icon name="calendar" size={14} /> {formatMonth(post.date)}</span>
                <span><Icon name="clock" size={14} /> {post.readTime}</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="reveal" style="text-align: center; margin-top: 42px;">
        <a class="button" href="/blog/">View all articles <Icon name="arrow-right" size={16} /></a>
      </div>
    </div>
  </section>

  <section class="section" id="contact">
    <div class="container two-column">
      <div class="section-header" style="margin-bottom: 0;">
        <div class="eyebrow reveal">Contact</div>
        <h2 class="reveal">Bring a concrete product or GTM problem</h2>
      </div>
      <div class="contact-box card reveal">
        <p class="lead">Reach out if you want to compare notes on Luminik, event pipeline, founder-led sales, or turning repeated customer work into product.</p>
        <div class="hero-actions">
          <a class="button primary" href="mailto:prasadus92@gmail.com"><Icon name="envelope" size={16} /> Email</a>
          <a class="button" href="/intro-chat/"><Icon name="calendar" size={16} /> Intro chat</a>
          <a class="button" href="https://linkedin.com/in/prasadus" target="_blank" rel="noopener"><Icon name="linkedin" size={16} /> LinkedIn</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
