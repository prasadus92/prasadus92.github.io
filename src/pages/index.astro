---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import ProofStrip from '../components/islands/ProofStrip';
import type { ProofPoint } from '../components/islands/ProofStrip';
import { featuredPosts, formatMonth } from '../lib/posts';

const proofPoints: ProofPoint[] = [
  {
    label: 'Aura at Bain',
    value: '$3.6M ARR',
    numericValue: 3.6,
    prefix: '$',
    suffix: 'M ARR',
    caption: 'Built a PE due diligence platform inside Bain and took it from concept to revenue in 18 months.'
  },
  {
    label: 'Mainteny',
    value: '$2.7M raised',
    numericValue: 2.7,
    prefix: '$',
    suffix: 'M seed',
    caption: 'Co-founded Mainteny, built the first field-service product version in 3 months, and helped make the seed story concrete with a live product and customer evidence.'
  },
  {
    label: 'Solo builder',
    value: '12+ years',
    numericValue: 12,
    suffix: '+ years',
    caption: 'Engineering, product, and founder-led GTM across 4 companies. Now building Luminik.'
  }
];

const title = 'Prasad Subrahmanya';
const description = 'Founder of Luminik. I write about doing painful customer work first, then turning the repeated parts into B2B software. Built Aura at Bain to $3.6M ARR and co-founded Mainteny through its $2.7M seed.';
---

<BaseLayout
  title={title}
  description={description}
  canonical="https://prasad.tech/"
  active="home"
  preloadImage
  image="/og/prasad-og.png"
  imageAlt="Prasad Subrahmanya | Founder of Luminik. Do the customer's work first."
>

  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <div class="eyebrow reveal">Customer work first</div>
        <h1 class="reveal">Do the customer's work first.</h1>
        <p class="lead reveal">
          I'm Prasad Subrahmanya. I enter the customer's workflow, do the painful manual work myself, and turn repeated pain into software. Today I run <a href="https://www.luminik.io" target="_blank" rel="noopener">Luminik</a>, an event pipeline platform for B2B teams.
        </p>
        <div class="hero-actions reveal">
          <a href="/blog/" class="button primary"><Icon name="book-open" size={16} /> Read the field notes</a>
          <a href="https://www.luminik.io" target="_blank" rel="noopener" class="text-link">Visit Luminik <Icon name="arrow-up-right" size={15} /></a>
        </div>
      </div>

      <div class="proof-card card reveal">
        <div class="proof-head">
          <img src="/assets/images/header/prasad.jpeg" width="76" height="76" alt="Prasad Subrahmanya" decoding="async" fetchpriority="high" />
          <div>
            <div class="eyebrow" style="margin-bottom: 4px;">Current work</div>
            <h2 style="font-size: 1.35rem; margin-bottom: 4px;">Luminik</h2>
            <p style="margin: 0; color: var(--text-3);">Event pipeline platform for B2B</p>
          </div>
        </div>
        <div class="proof-list">
          <div class="proof-item">
            <div class="proof-number">01</div>
            <p>Source, enrich, sequence, capture, and attribute event-sourced pipeline in the systems B2B teams already use.</p>
          </div>
          <div class="proof-item">
            <div class="proof-number">02</div>
            <p>Specs, repo rules, and PR review queues keep agent-written work tied to customer workflows and product decisions.</p>
          </div>
          <div class="proof-item">
            <div class="proof-number">03</div>
            <p>Sales calls are product work. I sell early because a good buyer question can change the product before the wrong thing gets expensive.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section tight" id="track-record" aria-labelledby="track-record-heading">
    <div class="container">
      <div class="section-header">
        <div class="eyebrow reveal">Track record</div>
        <h2 class="reveal" id="track-record-heading">A few outcomes from shipped work</h2>
        <p class="lead reveal">
          I have built revenue-generating software inside Bain, co-founded a venture-backed company, and shipped the first product myself before the team existed.
        </p>
      </div>
      <ProofStrip points={proofPoints} client:visible />
    </div>
  </section>

  <section class="section" id="about">
    <div class="container two-column">
      <div class="section-header" style="margin-bottom: 0;">
        <div class="eyebrow reveal">About</div>
        <h2 class="reveal">The work before software becomes obvious</h2>
      </div>
      <div>
        <p class="lead reveal">
          Good B2B software often starts as work someone is doing by hand: chasing updates, reconciling data, explaining status, fixing edge cases. I care about that stretch: manual delivery, narrow first versions, sales calls that change the product, architecture choices that save future work, and review gates that keep agents accountable.
        </p>
        <p class="lead reveal">
          Right now I am building Luminik. Before that I built SnowOptix, Aura at Bain, and Mainteny. Each one started in a different context. The useful habit stayed the same: enter the workflow, do enough of it by hand to know where it hurts, ship the smallest useful system, then make it clear enough that customers, teammates, and investors can trust it.
        </p>
      </div>
    </div>
  </section>

  <section class="section" id="operating-areas">
    <div class="container">
      <div class="section-header center">
        <div class="eyebrow reveal">Operating areas</div>
        <h2 class="reveal">What I build and write about</h2>
        <p class="lead reveal">Useful notes for technical founders turning customer work into software.</p>
      </div>

      <div class="path-grid">
        <div class="path-card card interactive reveal">
          <h3>Solo product engineering</h3>
          <p>Ship the first useful workflow. Keep scope small until the product earns more architecture.</p>
        </div>
        <div class="path-card card interactive reveal">
          <h3>Founder-led GTM</h3>
          <p>Use sales calls to understand how buyers already work, what hurts, and what they will change for.</p>
        </div>
        <div class="path-card card interactive reveal">
          <h3>Agent-assisted work</h3>
          <p>Use specs, repo rules, and PR review queues to keep agent-written work tied to product decisions.</p>
        </div>
        <div class="path-card card interactive reveal">
          <h3>Event pipeline systems</h3>
          <p>The data model behind event ROI: sourcing, enrichment, sequencing, capture, and attribution as one record.</p>
        </div>
      </div>

      <div class="artifact-map" style="margin-top: 34px;">
        <div class="artifact-node card reveal">
          <span>01</span>
          <strong>Customer work</strong>
          <p>Start with the task the buyer is already doing by hand.</p>
        </div>
        <div class="artifact-node card reveal">
          <span>02</span>
          <strong>Manual delivery</strong>
          <p>Do it yourself before freezing the product shape.</p>
        </div>
        <div class="artifact-node card reveal">
          <span>03</span>
          <strong>Narrow software</strong>
          <p>Automate the repeated pain. Leave the rare cases visible.</p>
        </div>
        <div class="artifact-node card reveal">
          <span>04</span>
          <strong>Review gates</strong>
          <p>Use agents and specs without giving up accountability.</p>
        </div>
        <div class="artifact-node card reveal">
          <span>05</span>
          <strong>Trust</strong>
          <p>Make the model clear enough for customers, teammates, and investors.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="experience">
    <div class="container">
      <div class="section-header">
        <div class="eyebrow reveal">Experience</div>
        <h2 class="reveal">Where I have built and shipped</h2>
        <p class="lead reveal">Different settings, same job: understand the business, build the product, sell the early version, and keep the operating model honest.</p>
      </div>

      <div class="experience-grid">
        <div class="experience-card card reveal">
          <div class="experience-top">
            <div>
              <p class="experience-company">Luminik</p>
              <h3>Founder</h3>
            </div>
            <span class="experience-date">Oct 2024 - Present</span>
          </div>
          <p>Building an event pipeline platform for B2B teams that need one record from source to attribution: source, enrich, sequence, capture, and attribute.</p>
          <div class="tag-row">
            <span class="tag">Event pipeline</span>
            <span class="tag">B2B GTM</span>
            <span class="tag">AI agents</span>
            <span class="tag">Founder-led sales</span>
          </div>
        </div>

        <div class="experience-card card reveal">
          <div class="experience-top">
            <div>
              <p class="experience-company">SnowOptix</p>
              <h3>Founder</h3>
            </div>
            <span class="experience-date">Jan 2024 - Oct 2024</span>
          </div>
          <p>A Snowflake cost optimization side project that entered Snowflake's Native App Accelerator with support from the startups team. The conversations showed the pain was real, but the market I wanted to build in was events.</p>
          <div class="tag-row">
            <span class="tag">Snowflake</span>
            <span class="tag">Data engineering</span>
            <span class="tag">Customer discovery</span>
          </div>
        </div>

        <div class="experience-card card reveal">
          <div class="experience-top">
            <div>
              <p class="experience-company">Bain & Company</p>
              <h3>Venture CTO</h3>
            </div>
            <span class="experience-date">Nov 2022 - Dec 2023</span>
          </div>
          <p>Built and scaled Aura, a PE due diligence SaaS platform, from concept to $3.6M ARR in 18 months.</p>
          <div class="tag-row">
            <span class="tag">SaaS</span>
            <span class="tag">Due diligence</span>
            <span class="tag">Venture building</span>
          </div>
        </div>

        <div class="experience-card card reveal">
          <div class="experience-top">
            <div>
              <p class="experience-company">Mainteny</p>
              <h3>Co-founder and CTO</h3>
            </div>
            <span class="experience-date">Aug 2020 - Oct 2022</span>
          </div>
          <p>Built the first field-service product version solo in 3 months, joined early customer and sales work, and helped make the seed story concrete with a live product and customer evidence.</p>
          <div class="tag-row">
            <span class="tag">Field service</span>
            <span class="tag">Elevator maintenance</span>
            <span class="tag">First product</span>
            <span class="tag">Fundraising</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="blog">
    <div class="container">
      <div class="section-header center">
        <div class="eyebrow reveal">Writing</div>
        <h2 class="reveal">Notes from the work</h2>
        <p class="lead reveal">Essays on building, selling, agent-written work, and the moment manual customer work becomes software.</p>
      </div>

      <div class="blog-grid">
        {featuredPosts.map((post) => (
          <a class="blog-card card interactive reveal" href={post.url}>
            <div class="blog-card-content">
              <span class="blog-category">{post.category}</span>
              <h3>{post.title}</h3>
              <p>{post.description}</p>
              <div class="blog-meta">
                <span><Icon name="calendar" size={14} /> {formatMonth(post.date)}</span>
                <span><Icon name="clock" size={14} /> {post.readTime}</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="reveal" style="text-align: center; margin-top: 42px;">
        <a class="button" href="/blog/">View all articles <Icon name="arrow-right" size={16} /></a>
      </div>
    </div>
  </section>

  <section class="section" id="contact">
    <div class="container two-column">
      <div class="section-header" style="margin-bottom: 0;">
        <div class="eyebrow reveal">Contact</div>
        <h2 class="reveal">Bring a concrete product or GTM problem</h2>
      </div>
      <div class="contact-box card reveal">
        <p class="lead">Reach out if you want to compare notes on Luminik, event pipeline, founder-led sales, or turning a painful workflow into product.</p>
        <div class="hero-actions">
          <a class="button primary" href="mailto:prasadus92@gmail.com"><Icon name="envelope" size={16} /> Email</a>
          <a class="button" href="/intro-chat/"><Icon name="calendar" size={16} /> Intro chat</a>
          <a class="button" href="https://linkedin.com/in/prasadus" target="_blank" rel="noopener"><Icon name="linkedin" size={16} /> LinkedIn</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
