---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
---

<BaseLayout
  title={`Book a call - ${site.name}`}
  description="Book a 15-minute call with Prasad Subrahmanya."
>
  <section class="book">
    <div class="container--prose book-head">
      <p class="eyebrow reveal">Booking</p>
      <h1 class="reveal reveal-d1">Book a call.</h1>
      <p class="book-lead muted reveal reveal-d2">
        A short intro call, no deck. If you're building something hard in AI or hiring for it, grab a
        time that works.
      </p>
    </div>
    <div class="container book-embed reveal reveal-d2">
      <div id="cal-inline" aria-label="Cal.com booking calendar"></div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (function (C, A, L) {
    let p = function (a, ar) {
      a.q.push(ar);
    };
    let d = C.document;
    C.Cal =
      C.Cal ||
      function () {
        let cal = C.Cal;
        let ar = arguments;
        if (!cal.loaded) {
          cal.ns = {};
          cal.q = cal.q || [];
          d.head.appendChild(d.createElement('script')).src = A;
          cal.loaded = true;
        }
        if (ar[0] === L) {
          const api = function () {
            p(api, arguments);
          };
          const namespace = ar[1];
          api.q = api.q || [];
          if (typeof namespace === 'string') {
            cal.ns[namespace] = cal.ns[namespace] || api;
            p(cal.ns[namespace], ar);
            p(cal, ['initNamespace', namespace]);
          } else p(cal, ar);
          return;
        }
        p(cal, ar);
      };
  })(window, 'https://app.cal.com/embed/embed.js', 'init');

  Cal('init', 'intro', { origin: 'https://cal.com' });

  const root = document.documentElement;
  const el = document.getElementById('cal-inline');
  const getTheme = () => (root.getAttribute('data-theme') === 'light' ? 'light' : 'dark');

  // Render the Intro Chat event directly (not the profile page), 20 min default.
  function renderCal() {
    const theme = getTheme();
    el.innerHTML = '';
    Cal.ns.intro('inline', {
      elementOrSelector: '#cal-inline',
      config: { layout: 'month_view', theme: theme, duration: '20' },
      calLink: 'meet-prasad/intro-chat',
    });
    Cal.ns.intro('ui', { hideEventTypeDetails: false, layout: 'month_view', theme: theme });
  }
  renderCal();

  // Keep the embed in sync with the site's light/dark theme (toggle or system).
  let lastTheme = getTheme();
  new MutationObserver(() => {
    const t = getTheme();
    if (t !== lastTheme) {
      lastTheme = t;
      renderCal();
    }
  }).observe(root, { attributes: true, attributeFilter: ['data-theme'] });
</script>

<style>
  .book {
    padding-top: clamp(116px, 14vh, 156px);
  }
  .book-head h1 {
    margin-top: 14px;
    font-size: clamp(2.2rem, 1.5rem + 3vw, 3.4rem);
  }
  .book-lead {
    margin-top: 18px;
    font-size: var(--fs-lead);
    line-height: 1.6;
  }
  .book-embed {
    margin-top: clamp(28px, 4vw, 44px);
  }
  #cal-inline {
    width: 100%;
    min-height: 680px;
    border: 1px solid var(--glass-border);
    border-radius: var(--r-lg);
    overflow: hidden;
    background: var(--glass-bg);
  }
</style>
