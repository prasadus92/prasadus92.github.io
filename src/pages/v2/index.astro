---
import V2Layout from "../../layouts/V2Layout.astro";
import Nav from "../../components/v2/Nav.astro";
import Footer from "../../components/v2/Footer.astro";
---
<V2Layout title="Prasad Subrahmanya · Builder & operator" description="I build Luminik, an event pipeline platform for B2B teams.">
  <Nav />
<main>
    <!-- ===== HERO ===== -->
    <section class="hero">
      <div class="container">
        <div class="hero-grid">
          <div class="hero-copy">
            <h1 class="display">I automate the <span class="redmark">B2B grind.</span><br>I sell before I build.<br>I'm Prasad Subrahmanya.</h1>
            <p class="lead reveal">
              I build <a href="https://www.luminik.io" target="_blank" rel="noopener">Luminik</a>, an event pipeline platform for B2B teams.
            </p>
            <div class="hero-actions reveal">
              <a class="btn red" href="#contact">Get in touch</a>
              <a class="icon-btn" href="https://github.com/prasadus92" target="_blank" rel="noopener" aria-label="GitHub"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .322.216.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg></a>
              <a class="icon-btn" href="https://linkedin.com/in/prasadus" target="_blank" rel="noopener" aria-label="LinkedIn"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></a>
              <a class="txt-link" href="https://www.luminik.io" target="_blank" rel="noopener">luminik.io <span class="a">↗</span></a>
            </div>
          </div>

          <div class="reveal">
            <div class="portrait">
              <div class="frame"><img src="/assets/v2/prasad.jpeg" alt="Prasad Subrahmanya" width="800" height="800" /></div>
              <span class="vlabel"><span>Founder · Builder · Operator</span></span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== TRACK RECORD ===== -->
    <section class="band" id="track">
      <div class="container">
        <div class="head split reveal">
          <div>
            <span class="kicker red">Track record</span>
            <h2>The work converts to <span class="redmark">revenue.</span></h2>
          </div>
          <p class="lead">3x technical founder. Pipeline sourced for customers, ARR built from zero, products people pay for.</p>
        </div>

        <div class="ship reveal">
          <div class="ship-head">
            <span class="kicker red">I ship · last 90 days</span>
            <a class="ship-link" href="https://github.com/prasadus92" target="_blank" rel="noopener">@prasadus92 ↗</a>
          </div>
          <div class="ship-body">
            <div class="ship-stat">
              <div class="ship-num"><span id="ship-num">0</span><span class="ship-den">/90</span></div>
              <div class="ship-num-cap">days shipping code</div>
              <div class="ship-streak" id="ship-streak"></div>
            </div>
            <div class="ship-graph" id="ship-graph" aria-label="GitHub contributions, last 90 days"></div>
          </div>
          <p class="ship-note" id="ship-note">This is just the public footprint. Most product and client work ships in private repos.</p>
        </div>

        <div class="stats reveal">
          <div class="stat"><div class="lbl">Customer pipeline</div><div class="big" data-count="6" data-prefix="$" data-suffix="M+" data-dec="0">$6M+</div><p>Pipeline sourced for customers at Luminik, connecting B2B event spend to real revenue.</p></div>
          <div class="stat"><div class="lbl">Aura · Bain</div><div class="big" data-count="3.6" data-prefix="$" data-suffix="M" data-dec="1">$3.6M</div><p>ARR built from zero in 15 months as venture CTO, used by top private equity and growth firms.</p></div>
          <div class="stat"><div class="lbl">Technical founder</div><div class="big" data-count="3" data-suffix="×" data-dec="0">3×</div><p>Founded Luminik, SnowOptix, and Mainteny. Hands-on from first commit to scaled team.</p></div>
        </div>
      </div>
    </section>

    <!-- ===== BLACK SECTION + RED GRADIENT (manifesto) ===== -->
    <section class="band dark" id="approach">
      <div class="container">
        <div class="head split reveal">
          <div>
            <span class="kicker red">Approach</span>
            <h2>Six rules I <span class="redmark">build by.</span></h2>
          </div>
          <p class="lead">Learned from putting agents in front of real customers, where demos do not count.</p>
        </div>
        <div class="principles reveal">
          <div class="principle"><div class="n">01</div><h3>Get close to the problem</h3><p>I work next to the people who have the problem, so the product comes from what they do day to day.</p></div>
          <div class="principle"><div class="n">02</div><h3>Treat agents as systems</h3><p>An agent is more than a prompt. It needs planning, isolation, review, and a way to recover when it goes wrong. Alfred runs a fleet of coding agents on those rules.</p></div>
          <div class="principle"><div class="n">03</div><h3>Earn trust before production</h3><p>Demos are easy. I spend the real effort on the cases that break: evals, a judge I have calibrated, and adversarial tests, so I know how a system behaves before customers meet it.</p></div>
          <div class="principle"><div class="n">04</div><h3>Expect failure</h3><p>Long-running AI work fails partway through. I build so a run can crash, retry, and pick up again without losing data or repeating work.</p></div>
          <div class="principle"><div class="n">05</div><h3>Measure what matters</h3><p>I tie systems to the number the business cares about: pipeline, revenue, and cost. If I cannot see the effect, I am careful about shipping.</p></div>
          <div class="principle"><div class="n">06</div><h3>Stay hands-on</h3><p>I write code, review it, and read what the system produces in the wild. This work is hard to lead from a distance.</p></div>
        </div>
      </div>
    </section>

    <!-- ===== OPERATING AREAS ===== -->
    <section class="band" id="operating">
      <div class="container">
        <div class="head split reveal">
          <div>
            <span class="kicker red">Skills</span>
            <h2>The stack I'm <span class="redmark">hands-on with.</span></h2>
          </div>
          <p class="lead">Where I build, by area. Real tools, running in production.</p>
        </div>
        <div class="skills-bento reveal">
          <div class="skill-cell wide"><span class="n">01</span><h3>AI-native engineering</h3><p>Autonomous agent fleets (Alfred), Claude Code + Codex, Anthropic + OpenAI SDKs, LangGraph, MCP, multi-agent orchestration.</p></div>
          <div class="skill-cell"><span class="n">02</span><h3>Retrieval &amp; memory</h3><p>Vector databases (pgvector), embeddings, hybrid retrieval, Redis agent memory, context engineering, reviewable promotion gates.</p></div>
          <div class="skill-cell"><span class="n">03</span><h3>Evals &amp; benchmarking</h3><p>LLM-as-judge gates, Langfuse, classifiers, structured multi-axis review, adversarial suites.</p></div>
          <div class="skill-cell"><span class="n">04</span><h3>Observability &amp; reliability</h3><p>Langfuse tracing, OpenTelemetry, Sentry, spend and failure telemetry, fleet health loops.</p></div>
          <div class="skill-cell"><span class="n">05</span><h3>Distributed systems</h3><p>Hatchet, Temporal, FastAPI, Pydantic, Quarkus + Kotlin, Postgres, AWS.</p></div>
          <div class="skill-cell wide"><span class="n">06</span><h3>Product &amp; platform</h3><p>Next.js, React + TypeScript, Expo, Tauri, Nango, Terraform, Playwright.</p></div>
        </div>
      </div>
    </section>

    <!-- ===== PROCESS (red strip) ===== -->
    <section class="process">
      <div class="container">
        <div class="proc-head reveal"><span class="kicker">How my systems run</span></div>
        <div class="proc-grid reveal">
          <div class="pstep"><div class="n">01</div><strong>Signals</strong><p>Events, CRM, and product data come in as the raw input.</p></div>
          <div class="pstep"><div class="n">02</div><strong>Agents</strong><p>Agents plan, act, and hand the work off to each other.</p></div>
          <div class="pstep"><div class="n">03</div><strong>Evals</strong><p>Judges, guardrails, and error bars prove the behavior first.</p></div>
          <div class="pstep"><div class="n">04</div><strong>Durable runs</strong><p>Every run can retry, resume, and recover without losing work.</p></div>
          <div class="pstep"><div class="n">05</div><strong>Outcomes</strong><p>It all ties back to pipeline, ARR, and resolution.</p></div>
        </div>
      </div>
    </section>

    <!-- ===== EXPERIENCE ===== -->
    <section class="band" id="experience">
      <div class="container">
        <div class="head split reveal">
          <div>
            <span class="kicker red">Work</span>
            <h2>I build the first version, <span class="redmark">then the team.</span></h2>
          </div>
          <p class="lead">3x technical founder. Across four companies I've owned the product, the architecture, and the people who build it.</p>
        </div>
        <div class="exp-list">
          <div class="exp reveal">
            <div><div class="exp-co">Luminik</div><div class="exp-role">Founder &amp; CEO</div></div>
            <div class="exp-body"><p>Building a multi-agent platform that connects B2B event spend to measurable pipeline: attendee extraction, enrichment, ICP matching, outbound, CRM sync, and revenue attribution. Powering GTM teams at flagship events.</p>
              <div class="tags"><span class="tag">Multi-agent</span><span class="tag">Next.js</span><span class="tag">Python</span><span class="tag">Hatchet</span><span class="tag">Vector search</span><span class="tag">AWS</span></div></div>
            <div class="exp-date">Oct 2024 – Present</div>
          </div>
          <div class="exp reveal">
            <div><div class="exp-co">SnowOptix</div><div class="exp-role">Founder</div></div>
            <div class="exp-body"><p>A Snowflake cost-optimization tool. It was used by one of the global top-3 consulting firms, and the conversations while building it surfaced the bigger problem that became Luminik.</p>
              <div class="tags"><span class="tag">Snowflake</span><span class="tag">Data engineering</span><span class="tag">Cost optimization</span></div></div>
            <div class="exp-date">Jan 2024 – Oct 2024</div>
          </div>
          <div class="exp reveal">
            <div><div class="exp-co">Aura · Bain &amp; Company</div><div class="exp-role">Venture CTO</div></div>
            <div class="exp-body"><p>Took a PE due-diligence SaaS platform from concept to $3.6M ARR in 15 months. Owned product, architecture, and the engineering team. Some of the largest names in growth equity and private equity ran their diligence on it.</p>
              <div class="tags"><span class="tag">Enterprise SaaS</span><span class="tag">AWS</span><span class="tag">PE &amp; growth equity</span><span class="tag">Team leadership</span></div></div>
            <div class="exp-date">Nov 2022 – Dec 2023</div>
          </div>
          <div class="exp reveal">
            <div><div class="exp-co">Mainteny</div><div class="exp-role">Co-founder &amp; CTO</div></div>
            <div class="exp-body"><p>Field-service management SaaS for maintenance companies across Europe. Built and launched the MVP solo in 3 months, raised a $2.7M seed, and scaled the team to 15 across four countries.</p>
              <div class="tags"><span class="tag">Spring Boot</span><span class="tag">Kubernetes</span><span class="tag">$2.7M seed</span><span class="tag">CRM</span></div></div>
            <div class="exp-date">Aug 2020 – Oct 2022</div>
          </div>
          <div class="exp reveal">
            <div><div class="exp-co">Earlier</div><div class="exp-role">Engineering</div></div>
            <div class="exp-body"><p>Engineering Manager at Quantumrock (BaFin-regulated algorithmic trading, Munich). Senior Software Engineer at Wirecard (PCI-DSS card processing at scale, Munich). Software Engineer at CommerceIQ (retail price intelligence, 100M+ SKUs/day). Platform Engineer at BlueJeans, later Verizon (video platform, recording v1.0, Bangalore).</p>
              <div class="tags"><span class="tag">Quantumrock</span><span class="tag">Wirecard</span><span class="tag">CommerceIQ</span><span class="tag">BlueJeans / Verizon</span></div></div>
            <div class="exp-date">2014 – 2020</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== WRITING ===== -->
    <section class="band" id="writing">
      <div class="container">
        <div class="head split reveal">
          <div>
            <span class="kicker red">Writing</span>
            <h2>Primers on what I <span class="redmark">actually build.</span></h2>
          </div>
          <p class="lead">Field notes and first-principles primers on the systems behind the work.</p>
        </div>
        <div class="writing-feature reveal">
          <a class="post-lead" href="#">
            <span class="cat">AI engineering · 16 min</span>
            <h3>OCR and the offline reality: reading text on a phone with no signal</h3>
            <p>Why OCR is harder than it looks, why the public datasets skew Latin, and why production offline OCR still runs on classical and CNN/transformer engines like Tesseract, Apple Vision, ML Kit, and PaddleOCR rather than a full VLM on the phone.</p>
            <span class="post-read">Jul 2026 · Read <span class="a">↗</span></span>
          </a>
          <div class="post-pair">
            <a class="post-sm" href="#">
              <span class="cat">Engineering · 14 min</span>
              <h3>Scaling WebSockets: what changes when the connection never closes</h3>
              <span class="post-read">Jul 2026 <span class="a">↗</span></span>
            </a>
            <a class="post-sm" href="#">
              <span class="cat">Engineering · 13 min</span>
              <h3>WebSockets, SSE, and HTTP/3 from first principles</h3>
              <span class="post-read">Jul 2026 <span class="a">↗</span></span>
            </a>
          </div>
        </div>
        <div class="reveal" style="text-align:center;margin-top:42px;">
          <a class="btn black" href="/v2/blog">View all articles <span class="a">→</span></a>
        </div>
      </div>
    </section>

    <!-- ===== CONTACT (full red) ===== -->
    <section class="contact" id="contact">
      <div class="container contact-grid">
        <div class="reveal">
          <span class="kicker">Contact</span>
          <h2>Let's <span class="r">talk.</span></h2>
        </div>
        <div class="reveal">
          <p class="lead">If you're building something hard in AI, or hiring someone who has, I'd like to hear about it.</p>
          <div class="contact-actions">
            <a class="btn red" href="mailto:prasadus92@gmail.com">Book a 15-min call ↗</a>
            <a class="btn on-dark" href="mailto:prasadus92@gmail.com">Email</a>
            <a class="btn on-dark" href="https://linkedin.com/in/prasadus" target="_blank" rel="noopener">LinkedIn</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <script is:inline>

    const io=new IntersectionObserver((es)=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}});},{threshold:.12,rootMargin:'0px 0px -7% 0px'});
    document.querySelectorAll('.reveal').forEach((el,i)=>{el.style.transitionDelay=Math.min(i%5,4)*50+'ms';io.observe(el);});

    // typewriter build for the hero headline: types line by line, preserving the red highlight
    (function(){
      const h1=document.querySelector('.display');
      if(!h1) return;
      if(window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      const ops=[];
      h1.childNodes.forEach(n=>{
        if(n.nodeType===3){ if(n.textContent) ops.push({t:'text',s:n.textContent}); }
        else if(n.nodeName==='BR'){ ops.push({t:'br'}); }
        else ops.push({t:'span',cls:n.getAttribute('class')||'',s:n.textContent});
      });
      const run=()=>{
        h1.textContent='';
        const caret=document.createElement('span'); caret.className='caret'; h1.appendChild(caret);
        let oi=0,ci=0,cur=null; const SPEED=42, LINE_PAUSE=200;
        const tick=()=>{
          if(oi>=ops.length){ setTimeout(()=>caret.remove(),1400); return; }
          const op=ops[oi];
          if(op.t==='br'){ h1.insertBefore(document.createElement('br'),caret); oi++; ci=0; cur=null; return setTimeout(tick,LINE_PAUSE); }
          if(ci===0){ cur=document.createElement('span'); if(op.t==='span'&&op.cls) cur.className=op.cls; h1.insertBefore(cur,caret); }
          cur.textContent=op.s.slice(0,++ci);
          if(ci>=op.s.length){ oi++; ci=0; cur=null; }
          setTimeout(tick,SPEED);
        };
        tick();
      };
      if(document.fonts&&document.fonts.ready) document.fonts.ready.then(run); else run();
    })();

    // count-up for the proof numbers, fires when they scroll into view
    (function(){
      const nums=[...document.querySelectorAll('.stat .big[data-count]')];
      if(!nums.length) return;
      const reduce=window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const fmt=(v,dec,pre,suf)=>pre+(dec>0?v.toFixed(dec):Math.round(v).toString())+suf;
      const animate=(el)=>{
        const to=parseFloat(el.dataset.count),dec=parseInt(el.dataset.dec||'0',10),pre=el.dataset.prefix||'',suf=el.dataset.suffix||'';
        if(reduce){ el.textContent=fmt(to,dec,pre,suf); return; }
        const dur=1100,t0=performance.now();
        const frame=(t)=>{ const p=Math.min(1,(t-t0)/dur),e=1-Math.pow(1-p,3); el.textContent=fmt(to*e,dec,pre,suf); if(p<1) requestAnimationFrame(frame); else el.textContent=fmt(to,dec,pre,suf); };
        requestAnimationFrame(frame);
      };
      const co=new IntersectionObserver((es)=>{es.forEach(e=>{if(e.isIntersecting){animate(e.target);co.unobserve(e.target);}});},{threshold:.5});
      nums.forEach(n=>co.observe(n));
    })();

    // I ship, last-90-days GitHub heatmap: busiest days in red, cells sweep in by week
    (function(){
      const el=document.getElementById('ship-graph');
      const numEl=document.getElementById('ship-num');
      const streakEl=document.getElementById('ship-streak');
      if(!el) return;
      const colors=['#ECECE9','#C2C2BC','#7A7A72','#1A1A1A','#E5241C']; // none → busy(red)
      const S=18,G=5,Rd=3;
      fetch('https://github-contributions-api.jogruber.de/v4/prasadus92?y=last')
        .then(r=>r.ok?r.json():Promise.reject(r.status))
        .then(data=>{
          const all=(data&&data.contributions)||[];
          if(!all.length) throw new Error('empty');
          const days=all.slice(-91);
          const weeks=[]; let cur=[];
          days.forEach(d=>{
            const wd=new Date(d.date+'T00:00:00').getDay();
            if(wd===0 && cur.length){weeks.push(cur);cur=[];}
            if(weeks.length===0 && cur.length===0){for(let k=0;k<wd;k++)cur.push(null);}
            cur.push(d);
          });
          if(cur.length) weeks.push(cur);
          const W=weeks.length*(S+G)-G, H=7*(S+G)-G;
          let rects='';
          weeks.forEach((wk,x)=>wk.forEach((d,y)=>{ if(!d) return; rects+='<rect x="'+(x*(S+G))+'" y="'+(y*(S+G))+'" width="'+S+'" height="'+S+'" rx="'+Rd+'" fill="'+colors[d.level||0]+'" style="--c:'+x+'"></rect>'; }));
          el.innerHTML='<svg viewBox="0 0 '+W+' '+H+'" width="'+W+'" height="'+H+'" role="img" aria-label="GitHub contributions, last 90 days">'+rects+'</svg>';
          const active=days.filter(d=>d.count>0).length;
          let i=days.length-1; if(days[i].count===0) i--; let streak=0; for(;i>=0&&days[i].count>0;i--) streak++;
          if(streakEl) streakEl.textContent=streak+'-day active streak';
          const reduce=window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          const reveal=()=>{
            el.classList.add('in');
            if(!numEl) return;
            if(reduce){ numEl.textContent=active; return; }
            const dur=1200,t0=performance.now();
            const fr=(t)=>{const p=Math.min(1,(t-t0)/dur),e=1-Math.pow(1-p,3);numEl.textContent=Math.round(active*e);if(p<1)requestAnimationFrame(fr);else numEl.textContent=active;};
            requestAnimationFrame(fr);
          };
          if(reduce){ reveal(); }
          else {
            const io=new IntersectionObserver((es)=>{es.forEach(e=>{if(e.isIntersecting){reveal();io.disconnect();}});},{threshold:.2});
            io.observe(el);
            setTimeout(()=>{const r=el.getBoundingClientRect();if(!el.classList.contains('in')&&r.top<innerHeight*0.95&&r.bottom>0){reveal();io.disconnect();}},900);
          }
        })
        .catch(()=>{ const ship=document.querySelector('.ship'); if(ship) ship.remove(); });
    })();

    // footer: copy the page's text content for pasting into an LLM
    (function(){
      const btn=document.getElementById('copy-page');
      if(!btn||!navigator.clipboard) return;
      btn.addEventListener('click',()=>{
        const main=document.querySelector('main');
        const text=(main?main.innerText:document.body.innerText).replace(/\n{3,}/g,'\n\n').trim();
        navigator.clipboard.writeText(text).then(()=>{
          const label=btn.textContent; btn.textContent='Copied'; btn.style.borderColor='#E5241C';
          setTimeout(()=>{ btn.textContent=label; btn.style.borderColor=''; },1600);
        }).catch(()=>{});
      });
    })();
  
  </script>
</V2Layout>
