---
interface Props {
  hostId?: string;
  class?: string;
}

const { hostId = 'my-cal-inline-intro-chat', class: className = '' } = Astro.props;
const namespace = 'intro-chat';
const calLink = 'meet-prasad/intro-chat';
const inlineConfig = {
  layout: 'month_view',
  useSlotsViewOnSmallScreen: 'true',
  duration: '20',
  hideEventTypeDetails: 'true'
};
---

<div class={`cal-embed ${className}`}>
  <div id={hostId} class="cal-embed-frame" aria-label="Intro chat calendar"></div>
</div>
<script is:inline define:vars={{ HOST_ID: hostId, NS: namespace, CAL_LINK: calLink, INLINE_CONFIG: inlineConfig }}>
  (function () {
    if (!window.__prasadCalLoaded) {
      window.__prasadCalLoaded = true;
      (function (C, A, L) {
        var p = function (a, ar) { a.q.push(ar); };
        var d = C.document;
        C.Cal = C.Cal || function () {
          var cal = C.Cal;
          var ar = arguments;
          if (!cal.loaded) {
            cal.ns = {};
            cal.q = cal.q || [];
            d.head.appendChild(d.createElement("script")).src = A;
            cal.loaded = true;
          }
          if (ar[0] === L) {
            function api() { p(api, arguments); }
            var namespace = ar[1];
            api.q = api.q || [];
            if (typeof namespace === "string") {
              cal.ns[namespace] = cal.ns[namespace] || api;
              p(cal.ns[namespace], ar);
              p(cal, ["initNamespace", namespace]);
            } else {
              p(cal, ar);
            }
            return;
          }
          p(cal, ar);
        };
      })(window, "https://app.cal.com/embed/embed.js", "init");
    }

    try {
      window.Cal("init", NS, { origin: "https://app.cal.com" });

      function currentTheme() {
        return document.documentElement.getAttribute("data-theme") === "light" ? "light" : "dark";
      }

      function applyUi() {
        try {
          window.Cal.ns[NS]("ui", {
            theme: currentTheme(),
            cssVarsPerTheme: {
              light: {
                "cal-brand": "#5ee7b5",
                "cal-brand-emphasis": "#22c997",
                "cal-brand-text": "#07100d",
                "cal-bg": "#f7f8f5",
                "cal-bg-emphasis": "#edf2ed",
                "cal-bg-muted": "#e5ebe5",
                "cal-bg-subtle": "#f2f5f1",
                "cal-text": "#18211d",
                "cal-text-emphasis": "#07100d",
                "cal-text-muted": "#647067",
                "cal-border": "#d6ded7",
                "cal-border-default": "#d6ded7",
                "cal-border-emphasis": "#b9c6bd",
                "cal-border-subtle": "#e5ebe5",
                "cal-border-booker": "#d6ded7",
                "cal-radius": "8px",
                "cal-radius-md": "8px",
                "cal-radius-lg": "8px"
              },
              dark: {
                "cal-brand": "#5ee7b5",
                "cal-brand-emphasis": "#7df0c7",
                "cal-brand-text": "#07100d",
                "cal-bg": "#12171f",
                "cal-bg-emphasis": "#1b2230",
                "cal-bg-muted": "#0b0d10",
                "cal-bg-subtle": "#171d27",
                "cal-text": "#f8fafc",
                "cal-text-emphasis": "#ffffff",
                "cal-text-muted": "#a8b3b9",
                "cal-border": "#2d3745",
                "cal-border-default": "#2d3745",
                "cal-border-emphasis": "#3a4658",
                "cal-border-subtle": "#202836",
                "cal-border-booker": "#2d3745",
                "cal-radius": "8px",
                "cal-radius-md": "8px",
                "cal-radius-lg": "8px"
              }
            },
            hideEventTypeDetails: true,
            showTimezoneWhenEventDetailsHidden: true,
            layout: "month_view"
          });
        } catch (e) {}
      }

      window.Cal.ns[NS]("inline", {
        elementOrSelector: "#" + HOST_ID,
        config: INLINE_CONFIG,
        calLink: CAL_LINK
      });

      applyUi();
      try {
        new MutationObserver(applyUi).observe(document.documentElement, {
          attributes: true,
          attributeFilter: ["data-theme"]
        });
      } catch (e) {}
    } catch (e) {}
  })();
</script>
