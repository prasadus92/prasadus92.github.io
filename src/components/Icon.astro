---
type IconName =
  | 'arrow-left'
  | 'arrow-right'
  | 'arrow-up-right'
  | 'book-open'
  | 'brain'
  | 'calendar'
  | 'clock'
  | 'comments'
  | 'envelope'
  | 'file-lines'
  | 'github'
  | 'linkedin'
  | 'moon'
  | 'sun';

type Props = {
  name: IconName;
  size?: number;
  class?: string;
  ariaLabel?: string;
};

const { name, size = 18, class: className, ariaLabel } = Astro.props;
const labelled = Boolean(ariaLabel);
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden={labelled ? undefined : 'true'}
  aria-label={labelled ? ariaLabel : undefined}
  role={labelled ? 'img' : undefined}
  focusable="false"
>
  {name === 'arrow-left' && (
    <>
      <line x1="19" y1="12" x2="5" y2="12" />
      <polyline points="12 19 5 12 12 5" />
    </>
  )}
  {name === 'arrow-right' && (
    <>
      <line x1="5" y1="12" x2="19" y2="12" />
      <polyline points="12 5 19 12 12 19" />
    </>
  )}
  {name === 'arrow-up-right' && (
    <>
      <line x1="7" y1="17" x2="17" y2="7" />
      <polyline points="7 7 17 7 17 17" />
    </>
  )}
  {name === 'book-open' && (
    <>
      <path d="M2 4h7a3 3 0 0 1 3 3v13a2 2 0 0 0-2-2H2z" />
      <path d="M22 4h-7a3 3 0 0 0-3 3v13a2 2 0 0 1 2-2h8z" />
    </>
  )}
  {name === 'brain' && (
    <>
      <path d="M12 5a3 3 0 1 0-5.997.142A4 4 0 0 0 4 9a4 4 0 0 0 1.236 2.886A4 4 0 0 0 8 18a3 3 0 0 0 4 0z" />
      <path d="M12 5a3 3 0 1 1 5.997.142A4 4 0 0 1 20 9a4 4 0 0 1-1.236 2.886A4 4 0 0 1 16 18a3 3 0 0 1-4 0z" />
      <path d="M12 5v13" />
    </>
  )}
  {name === 'calendar' && (
    <>
      <rect x="3" y="4" width="18" height="18" rx="2" />
      <line x1="16" y1="2" x2="16" y2="6" />
      <line x1="8" y1="2" x2="8" y2="6" />
      <line x1="3" y1="10" x2="21" y2="10" />
    </>
  )}
  {name === 'clock' && (
    <>
      <circle cx="12" cy="12" r="9" />
      <polyline points="12 7 12 12 15.5 14.5" />
    </>
  )}
  {name === 'comments' && (
    <>
      <path d="M21 12a8 8 0 0 1-11.3 7.3L3 21l1.7-6.7A8 8 0 1 1 21 12z" />
    </>
  )}
  {name === 'envelope' && (
    <>
      <rect x="3" y="5" width="18" height="14" rx="2" />
      <polyline points="3 7 12 13 21 7" />
    </>
  )}
  {name === 'file-lines' && (
    <>
      <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z" />
      <polyline points="14 3 14 8 19 8" />
      <line x1="9" y1="13" x2="15" y2="13" />
      <line x1="9" y1="17" x2="15" y2="17" />
    </>
  )}
  {name === 'github' && (
    <path
      fill="currentColor"
      stroke="none"
      d="M12 1.5A10.5 10.5 0 0 0 1.5 12c0 4.64 3.01 8.57 7.18 9.96.53.1.72-.23.72-.51 0-.25-.01-.92-.01-1.81-2.92.63-3.54-1.4-3.54-1.4-.48-1.21-1.17-1.54-1.17-1.54-.95-.65.07-.64.07-.64 1.06.07 1.61 1.09 1.61 1.09.94 1.6 2.46 1.14 3.06.87.09-.68.37-1.14.67-1.4-2.33-.27-4.78-1.16-4.78-5.18 0-1.14.41-2.08 1.08-2.81-.11-.27-.47-1.34.1-2.79 0 0 .88-.28 2.88 1.07a10 10 0 0 1 5.24 0c2-1.35 2.88-1.07 2.88-1.07.57 1.45.21 2.52.11 2.79.67.73 1.08 1.67 1.08 2.81 0 4.03-2.46 4.91-4.8 5.17.38.32.71.95.71 1.92 0 1.39-.01 2.51-.01 2.85 0 .28.19.61.73.5A10.5 10.5 0 0 0 22.5 12 10.5 10.5 0 0 0 12 1.5z"
    />
  )}
  {name === 'linkedin' && (
    <>
      <rect x="3" y="3" width="18" height="18" rx="3" />
      <line x1="8" y1="10" x2="8" y2="17" />
      <circle cx="8" cy="7" r="1.1" fill="currentColor" stroke="none" />
      <path d="M12 17v-4a2.5 2.5 0 0 1 5 0v4" />
      <line x1="12" y1="10" x2="12" y2="17" />
    </>
  )}
  {name === 'moon' && (
    <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
  )}
  {name === 'sun' && (
    <>
      <circle cx="12" cy="12" r="4" />
      <line x1="12" y1="2" x2="12" y2="5" />
      <line x1="12" y1="19" x2="12" y2="22" />
      <line x1="4.2" y1="4.2" x2="6.3" y2="6.3" />
      <line x1="17.7" y1="17.7" x2="19.8" y2="19.8" />
      <line x1="2" y1="12" x2="5" y2="12" />
      <line x1="19" y1="12" x2="22" y2="12" />
      <line x1="4.2" y1="19.8" x2="6.3" y2="17.7" />
      <line x1="17.7" y1="6.3" x2="19.8" y2="4.2" />
    </>
  )}
</svg>
