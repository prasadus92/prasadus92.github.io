---
// Consent-gated PostHog. Loads only after the visitor accepts analytics in the
// cookie banner (same gate as Analytics.astro). Every event is tagged with the
// A/B design variant (from the `ab_variant` cookie the edge Worker sets), and we
// capture the conversion + engagement events that matter: contact/booking views,
// CTA/booking clicks, blog scroll depth, and the "For AI" helper clicks. The
// project key is public by design (client-side); the personal key never ships.
const POSTHOG_KEY = 'phc_kFfPPQzwWBheGWctDsf3N7aXZamoJcdxXJ5Uv65g54ZH';
const POSTHOG_HOST = 'https://us.i.posthog.com';
const CONSENT_KEY = 'prasad-consent-v1';
---

<script is:inline define:vars={{ POSTHOG_KEY, POSTHOG_HOST, CONSENT_KEY }}>
  (function () {
    if (window.__phBootstrapped) return;
    window.__phBootstrapped = true;
    var loaded = false;

    function readConsent() {
      try {
        var raw = localStorage.getItem(CONSENT_KEY);
        if (!raw) return null;
        var p = JSON.parse(raw);
        return p && p.version === 1 ? p : null;
      } catch (e) {
        return null;
      }
    }
    function abVariant() {
      var m = document.cookie.match(/ab_variant=(a|b)/);
      return m ? m[1] : 'unknown';
    }
    function designName() {
      var v = abVariant();
      return v === 'a' ? 'v1' : v === 'b' ? 'v2' : 'unknown';
    }

    function wireEvents() {
      var path = location.pathname;
      if (path.indexOf('/contact') === 0 || path.indexOf('/v2/contact') === 0) {
        posthog.capture('contact_page_view');
      }
      if (path.indexOf('/book') === 0 || path.indexOf('/v2/book') === 0) {
        posthog.capture('booking_page_view');
      }

      document.addEventListener(
        'click',
        function (ev) {
          var el = ev.target && ev.target.closest ? ev.target.closest('a,button') : null;
          if (!el) return;
          var href = (el.getAttribute && el.getAttribute('href')) || '';
          var txt = (el.textContent || '').trim().toLowerCase();
          if (
            href.indexOf('/book') > -1 ||
            href.indexOf('cal.com') > -1 ||
            txt.indexOf('get in touch') > -1 ||
            txt.indexOf('book a call') > -1
          ) {
            posthog.capture('cta_click', { label: txt.slice(0, 48), href: href });
          }
          if (txt === 'copy page' || txt === 'markdown' || txt === 'ask ai') {
            posthog.capture('ai_helper_click', { which: txt });
          }
        },
        true
      );

      if (/\/blog\//.test(path)) {
        var hit = { 25: false, 50: false, 75: false, 100: false };
        window.addEventListener(
          'scroll',
          function () {
            var h = document.documentElement;
            var pct = Math.round(((h.scrollTop + window.innerHeight) / h.scrollHeight) * 100);
            [25, 50, 75, 100].forEach(function (m) {
              if (!hit[m] && pct >= m) {
                hit[m] = true;
                posthog.capture('blog_scroll_depth', { depth: m });
              }
            });
          },
          { passive: true }
        );
      }
    }

    function loadPostHog() {
      if (loaded) return;
      loaded = true;
      !(function (t, e) {
        var o, n, p, r;
        e.__SV ||
          ((window.posthog = e),
          (e._i = []),
          (e.init = function (i, s, a) {
            function g(t, e) {
              var o = e.split('.');
              2 == o.length && ((t = t[o[0]]), (e = o[1])),
                (t[e] = function () {
                  t.push([e].concat(Array.prototype.slice.call(arguments, 0)));
                });
            }
            ((p = t.createElement('script')).type = 'text/javascript'),
              (p.async = !0),
              (p.src = s.api_host.replace('.i.posthog.com', '-assets.i.posthog.com') + '/static/array.js'),
              (r = t.getElementsByTagName('script')[0]).parentNode.insertBefore(p, r);
            var u = e;
            for (
              void 0 !== a ? (u = e[a] = []) : (a = 'posthog'),
                u.people = u.people || [],
                u.toString = function (t) {
                  var e = 'posthog';
                  return 'posthog' !== a && (e += '.' + a), t || (e += ' (stub)'), e;
                },
                u.people.toString = function () {
                  return u.toString(1) + '.people (stub)';
                },
                o =
                  'init capture register register_once register_for_session unregister opt_out_capturing has_opted_out_capturing opt_in_capturing reset isFeatureEnabled getFeatureFlag getFeatureFlagPayload reloadFeatureFlags group identify setPersonProperties setPersonPropertiesForFlags resetPersonPropertiesForFlags setGroupPropertiesForFlags resetGroupPropertiesForFlags resetGroups onFeatureFlags addFeatureFlagsHandler onSessionId getSurveys getActiveMatchingSurveys renderSurvey canRenderSurvey getNextSurveyStep'.split(
                    ' '
                  ),
                n = 0;
              n < o.length;
              n++
            )
              g(u, o[n]);
            e._i.push([i, s, a]);
          }),
          (e.__SV = 1));
      })(document, window.posthog || []);

      posthog.init(POSTHOG_KEY, {
        api_host: POSTHOG_HOST,
        defaults: '2026-05-30',
        capture_pageview: true,
        capture_pageleave: true,
        autocapture: true,
      });
      posthog.register({ design_variant: designName(), ab_variant: abVariant() });
      wireEvents();
    }

    function apply() {
      var c = readConsent() || window.PrasadConsent;
      if (c && c.analytics) loadPostHog();
      else if (loaded && window.posthog) {
        try {
          posthog.opt_out_capturing();
        } catch (e) {}
      }
    }

    apply();
    window.addEventListener('prasad:consent-changed', function (event) {
      if (event.detail && event.detail.analytics) loadPostHog();
      else if (window.posthog) {
        try {
          posthog.opt_out_capturing();
        } catch (e) {}
      }
    });
  })();
</script>
