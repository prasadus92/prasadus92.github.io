---
// v2 footer. Grouped into Explore / More / Building / Elsewhere (mirrors v1),
// with a working "For AI" utility row (copy page as markdown, view .md, ask AI).
// mdPath is optional: when omitted, the client resolves the markdown URL from the
// current path so the row works on every v2 page without threading a prop through.
const { mdPath } = Astro.props as { mdPath?: string };
---
<footer class="foot">
    <div class="container">
      <div class="foot-top">
        <div class="foot-brand">
          <span class="foot-mark">PS</span>
          <p class="foot-bio">3x technical founder building AI-native products from Oslo, Norway.</p>
        </div>
        <div class="foot-cols">
          <nav class="foot-col">
            <h4>Explore</h4>
            <a href="/v2#track">Impact</a>
            <a href="/v2#experience">Work</a>
            <a href="/v2/ai-enablement">AI enablement</a>
            <a href="/v2/story">Story</a>
            <a href="/v2/blog">Writing</a>
            <a href="/v2/glossary">Glossary</a>
          </nav>
          <nav class="foot-col">
            <h4>More</h4>
            <a href="/v2/book">Book a call</a>
            <a href="/v2#contact">Contact</a>
            <a href="/rss.xml">RSS</a>
            <a href="/sitemap-index.xml">Sitemap</a>
          </nav>
          <nav class="foot-col">
            <h4>Building</h4>
            <a href="https://www.luminik.io" target="_blank" rel="noopener">Luminik</a>
            <a href="https://github.com/luminik-io/alfred-os" target="_blank" rel="noopener">Alfred</a>
          </nav>
          <nav class="foot-col">
            <h4>Elsewhere</h4>
            <a href="https://linkedin.com/in/prasadus" target="_blank" rel="noopener">LinkedIn</a>
            <a href="https://github.com/prasadus92" target="_blank" rel="noopener">GitHub</a>
            <a href="mailto:prasadus92@gmail.com">Email</a>
            <a href="/v2/privacy">Privacy</a>
          </nav>
        </div>
      </div>
      <div class="foot-ai" data-md={mdPath}>
        <span class="foot-ai-label">For AI</span>
        <button class="foot-ai-btn" id="copy-page" type="button">Copy page</button>
        <a class="foot-ai-btn" id="md-link" href={mdPath ?? '#'} target="_blank" rel="noopener">Markdown</a>
        <a class="foot-ai-btn" id="ask-ai" href="#" target="_blank" rel="noopener">ChatGPT</a>
        <a class="foot-ai-btn" id="ask-claude" href="#" target="_blank" rel="noopener">Claude</a>
      </div>
      <div class="foot-bottom">
        <span class="foot-meta">© 2026 Prasad Subrahmanya. Built in Oslo, Norway. · DataRavel Inc. · Brevv Ventures OÜ</span>
        <div class="foot-social">
          <a href="https://linkedin.com/in/prasadus" target="_blank" rel="noopener" aria-label="LinkedIn"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></a>
          <a href="https://github.com/prasadus92" target="_blank" rel="noopener" aria-label="GitHub"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .322.216.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg></a>
          <a href="mailto:prasadus92@gmail.com" aria-label="Email"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M22 6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6zm-2 0l-8 5-8-5h16zm0 12H4V8l8 5 8-5v10z"/></svg></a>
        </div>
      </div>
    </div>
  </footer>

  <script is:inline>
    // Wire the footer "For AI" row on every v2 page. The markdown URL is either
    // passed in (data-md) or resolved from the current v2 path; the v2 pages share
    // v1's .md routes (e.g. /v2/blog/foo -> /blog/foo.md, /v2 -> /index.md).
    (function () {
      const row = document.querySelector('.foot-ai');
      if (!row) return;
      const copyBtn = document.getElementById('copy-page');
      const mdLink = document.getElementById('md-link');
      const askLink = document.getElementById('ask-ai');
      const askClaude = document.getElementById('ask-claude');

      const resolveMd = () => {
        const explicit = row.getAttribute('data-md');
        if (explicit) return explicit;
        const p = location.pathname.replace(/\/+$/, '');
        if (p === '/v2' || p === '') return '/index.md';
        const m = p.match(/^\/v2\/blog\/(.+)$/);
        if (m) return '/blog/' + m[1] + '.md';
        // static v2 pages that have a matching v1 .md route
        const known = ['story', 'contact', 'book'];
        const seg = p.replace(/^\/v2\//, '');
        if (known.includes(seg)) return '/' + seg + '.md';
        return null; // no dedicated markdown (e.g. blog index, glossary, privacy)
      };

      const md = resolveMd();
      const origin = location.origin;

      const wireAsk = (prompt) => {
        const q = encodeURIComponent(prompt);
        if (askLink) askLink.setAttribute('href', 'https://chatgpt.com/?q=' + q);
        if (askClaude) askClaude.setAttribute('href', 'https://claude.ai/new?q=' + q);
      };
      if (md) {
        if (mdLink) mdLink.setAttribute('href', md);
        wireAsk('Read ' + origin + md + ' and summarize it.');
      } else {
        // No markdown for this page: fall back to summarizing the live URL.
        if (mdLink) mdLink.style.display = 'none';
        wireAsk('Read ' + location.href + ' and summarize it.');
      }

      if (copyBtn) {
        copyBtn.addEventListener('click', async () => {
          const done = () => {
            const l = copyBtn.textContent;
            copyBtn.textContent = 'Copied';
            copyBtn.style.borderColor = '#E5241C';
            setTimeout(() => {
              copyBtn.textContent = l;
              copyBtn.style.borderColor = '';
            }, 1600);
          };
          try {
            let text;
            if (md) {
              const res = await fetch(md);
              text = await res.text();
            } else {
              const main = document.querySelector('main') || document.querySelector('.post') || document.body;
              text = main.innerText.replace(/\n{3,}/g, '\n\n').trim();
            }
            await navigator.clipboard.writeText(text);
            done();
          } catch (e) {
            copyBtn.textContent = 'Copy failed';
            setTimeout(() => { copyBtn.textContent = 'Copy page'; }, 1600);
          }
        });
      }
    })();
  </script>
