---
import Icon from './Icon.astro';
import PostArt from './PostArt.astro';
export interface Props {
  slug: string;
  title: string;
  description: string;
  pubDate: Date;
  category?: string;
  readingTime?: string;
  featured?: boolean;
  delay?: number;
}
const { slug, title, description, pubDate, category, readingTime, featured = false, delay = 1 } =
  Astro.props;
const dateStr = pubDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
---

<a href={`/blog/${slug}`} class={`bcard glass card reveal reveal-d${delay} ${featured ? 'feat' : ''}`}>
  <div class="bcard-art">
    <PostArt seed={slug} height="100%" compact={!featured} />
  </div>
  <div class="bcard-body">
    {featured && <span class="bcard-lead-tag">Latest</span>}
    <div class="bcard-top">
      {category && <span class="chip">{category}</span>}
      <span class="bcard-read mono">{readingTime}</span>
    </div>
    <h3 class="bcard-title">{title}</h3>
    <p class="bcard-desc">{description}</p>
    <div class="bcard-foot">
      <span class="mono">{dateStr}</span>
      <span class="bcard-go">Read <Icon name="arrowRight" size={15} /></span>
    </div>
  </div>
</a>

<style>
  .bcard {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    transition: transform var(--dur-2) var(--ease-out), border-color var(--dur-2) var(--ease-out),
      box-shadow var(--dur-2) var(--ease-out);
  }
  .bcard:hover {
    transform: translateY(-4px);
  }
  .bcard-art {
    height: 150px;
    flex: 0 0 auto;
    border-bottom: 1px solid var(--glass-border);
  }
  .bcard-art :global(.post-art) {
    height: 100% !important;
    border: none;
    border-radius: 0;
  }

  /* ---------- Featured (lead) card: wide, art beside a larger title ----------
     Promotes the newest post to a two-panel hero card that breaks the even
     grid rhythm. Collapses back to the stacked card layout on narrow screens. */
  .bcard.feat {
    grid-column: 1 / -1;
    flex-direction: row;
    align-items: stretch;
  }
  .bcard.feat .bcard-art {
    height: auto;
    flex: 0 0 44%;
    border-bottom: none;
    border-right: 1px solid var(--glass-border);
    min-height: 260px;
  }
  .bcard.feat .bcard-body {
    justify-content: center;
    padding: clamp(28px, 3.4vw, 48px);
  }
  .bcard.feat .bcard-title {
    font-size: clamp(1.5rem, 1.2rem + 1.4vw, 2.1rem);
    line-height: 1.15;
    letter-spacing: var(--tracking-tight);
  }
  .bcard.feat .bcard-desc {
    font-size: 1rem;
    max-width: 52ch;
    flex: 0 1 auto;
  }
  .bcard.feat .bcard-lead-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--accent);
  }
  .bcard.feat .bcard-lead-tag::before {
    content: '';
    width: 18px;
    height: 1px;
    background: linear-gradient(90deg, var(--accent), transparent);
  }
  .bcard.feat .bcard-lead-tag + .bcard-top {
    margin-top: var(--sp-4);
  }
  @media (max-width: 760px) {
    .bcard.feat {
      flex-direction: column;
    }
    .bcard.feat .bcard-art {
      flex: 0 0 auto;
      height: 150px;
      border-right: none;
      border-bottom: 1px solid var(--glass-border);
      min-height: 0;
    }
    .bcard.feat .bcard-body {
      padding: var(--card-pad);
    }
  }
  .bcard-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: var(--card-pad);
  }
  .bcard-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .bcard-read {
    font-size: var(--fs-xs);
    color: var(--text-tertiary);
  }
  .bcard-title {
    margin-top: var(--sp-4);
    font-size: 1.28rem;
    line-height: 1.25;
    transition: color var(--dur-1) var(--ease-out);
  }
  .bcard:hover .bcard-title {
    color: var(--accent);
  }
  .bcard-desc {
    margin-top: var(--sp-3);
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
    flex: 1;
  }
  .bcard-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: var(--sp-5);
    padding-top: var(--sp-4);
    border-top: 1px solid var(--glass-border);
    font-size: var(--fs-sm);
    color: var(--text-tertiary);
  }
  .bcard-go {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--accent);
    font-family: var(--font-display);
    font-weight: 500;
  }
  .bcard-go :global(svg) {
    transition: transform var(--dur-1) var(--ease-out);
  }
  .bcard:hover .bcard-go :global(svg) {
    transform: translateX(3px);
  }

</style>
