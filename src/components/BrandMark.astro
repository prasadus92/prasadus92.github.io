---
type Props = {
  size?: number;
  decorative?: boolean;
  label?: string;
  class?: string;
};

const { size = 34, decorative = true, label = 'Prasad Subrahmanya' } = Astro.props;
const className = Astro.props.class;
---

<svg
  class:list={['brand-mark', className]}
  width={size}
  height={size}
  viewBox="0 0 512 512"
  role={decorative ? undefined : 'img'}
  aria-hidden={decorative ? 'true' : undefined}
  aria-label={decorative ? undefined : label}
  xmlns="http://www.w3.org/2000/svg"
>
  <rect class="brand-mark-canvas" width="512" height="512" rx="96" />
  <rect class="brand-mark-face" x="42" y="42" width="428" height="428" rx="78" />
  <circle class="brand-mark-spark" cx="137" cy="164" r="10" />
  <text class="brand-mark-initials" x="122" y="305">PS</text>
  <path class="brand-mark-accent" d="M126 338H386" />
  <path class="brand-mark-muted-line" d="M126 373H282" />
</svg>
