---
import { Icon } from 'astro-icon/components';
import Lattice from './Lattice.astro';

/*
  System, as a full-bleed big-type statement band (DESIGN-IDEAS #1).
  Replaces the five-card flow. One large sentence with the accent on single
  words (signals / evals / outcomes), generous negative space, and a thin
  inline icon row underneath. This is a hinge between halves of the page, not
  a sixth card grid. Accent words are solid colour, never a fill (DESIGN.md).
*/

const steps = [
  { icon: 'lucide:radio', label: 'Signals' },
  { icon: 'lucide:bot', label: 'Agents' },
  { icon: 'lucide:shield-check', label: 'Evals' },
  { icon: 'lucide:refresh-cw', label: 'Durable runs' },
  { icon: 'lucide:trending-up', label: 'Outcomes' },
];
---

<section class="band" id="system" aria-labelledby="band-statement">
  <Lattice variant="divider" accent />
  <div class="container band-inner">
    <p class="eyebrow band-eyebrow reveal">System</p>

    <h2 id="band-statement" class="band-statement reveal reveal-d1">
      Most of what I build is one loop:
      <span class="grad-text">signals</span>, agents,
      <span class="grad-text">evals</span>, durable runs,
      <span class="grad-text">outcomes</span>.
    </h2>

    <ol class="band-steps reveal reveal-d2" aria-label="Signals to agents to evals to durable runs to outcomes">
      {
        steps.map((s, i) => (
          <li class="band-step">
            <span class="band-icon"><Icon name={s.icon} /></span>
            <span class="band-label">{s.label}</span>
            {i < steps.length - 1 && <span class="band-arrow" aria-hidden="true">→</span>}
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .band {
    position: relative;
    /* full-bleed: a quieter, flatter surface than the card sections, so the
       aurora ones around it feel like arrivals (DESIGN-IDEAS #5, calm version) */
    background: linear-gradient(180deg, transparent, var(--bg-2) 40%, var(--bg-2) 60%, transparent);
    padding-block: clamp(80px, 12vw, 168px);
    /* hairline top + bottom to mark it as a distinct band */
    border-top: 1px solid var(--glass-border);
    border-bottom: 1px solid var(--glass-border);
  }
  .band-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .band-eyebrow {
    justify-content: center;
  }
  .band-statement {
    margin-top: var(--sp-5);
    max-width: 18ch;
    /* the one place type goes big */
    font-size: clamp(2.1rem, 1.1rem + 4.2vw, 4.4rem);
    line-height: 1.08;
    letter-spacing: var(--tracking-tight);
    text-wrap: balance;
  }
  .band-steps {
    list-style: none;
    margin: clamp(40px, 5vw, 64px) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: clamp(10px, 1.6vw, 18px);
  }
  .band-step {
    display: inline-flex;
    align-items: center;
    gap: clamp(8px, 1vw, 12px);
    color: var(--text-tertiary);
  }
  .band-icon {
    display: grid;
    place-items: center;
    color: var(--accent);
  }
  .band-icon :global(svg) {
    width: 18px;
    height: 18px;
  }
  .band-label {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wide);
  }
  .band-arrow {
    margin-left: clamp(2px, 0.8vw, 10px);
    color: var(--text-tertiary);
    opacity: 0.5;
  }

  @media (max-width: 560px) {
    /* keep the inline row readable: drop the arrows, wrap as a tidy list */
    .band-arrow {
      display: none;
    }
    .band-steps {
      gap: 12px 18px;
    }
  }
</style>
