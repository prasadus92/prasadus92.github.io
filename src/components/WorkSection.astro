---
import SectionHeader from './SectionHeader.astro';
import Icon from './Icon.astro';
import { Icon as LIcon } from 'astro-icon/components';
import { work, earlier } from '../data/site';

/*
  Work as an alternating left/right timeline on a centre node spine
  (DESIGN-IDEAS #2). Entries zigzag across the spine to read as a path, not a
  stacked list. Collapses to a single left-aligned column on mobile (<=820px),
  which is also what reduced-motion users get (no layout dependency on motion).
*/
---

<section class="section" id="work">
  <div class="container">
    <SectionHeader
      eyebrow="Work"
      title="Where I've <span class='grad-text'>built and shipped</span>."
      lead="Founder and operator across events, private equity, field service, and algorithmic trading."
    />

    <div class="timeline">
      <span class="spine" aria-hidden="true"></span>
      {
        work.map((job, i) => (
          <article class={`job ${i % 2 === 0 ? 'left' : 'right'} reveal reveal-d${(i % 4) + 1}`}>
            <span class={`job-node ${job.current ? 'now' : ''}`} aria-hidden="true">
              <LIcon name={job.icon} />
            </span>
            <div class="job-card glass card">
              <div class="job-head">
                <div>
                  <h3 class="job-company">
                    {job.company}
                    {job.href && (
                      <a href={job.href} target="_blank" rel="noopener" aria-label={`Visit ${job.company}`}>
                        <Icon name="arrowUpRight" size={16} />
                      </a>
                    )}
                  </h3>
                  <p class="job-role">{job.role}</p>
                </div>
                <span class="job-period mono">{job.period}</span>
              </div>
              <p class="job-body">{job.body}</p>
              <div class="job-tags">
                {job.tags.map((t) => (
                  <span class="chip">{t}</span>
                ))}
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <div class="earlier reveal">
      <span class="earlier-label mono">Earlier</span>
      <div class="earlier-grid">
        {
          earlier.map((e) => (
            <div class="earlier-item">
              <strong>{e.company}</strong>
              <span class="earlier-role">{e.role}</span>
              <span class="earlier-note muted">{e.note}</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .timeline {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: clamp(28px, 4vw, 56px);
  }
  /* centre spine */
  .spine {
    position: absolute;
    top: 6px;
    bottom: 6px;
    left: 50%;
    width: 2px;
    transform: translateX(-50%);
    background: linear-gradient(180deg, transparent, var(--glass-border-strong) 8%, var(--glass-border-strong) 92%, transparent);
    pointer-events: none;
  }

  .job {
    position: relative;
    display: grid;
    /* [left half] [spine gutter] [right half] */
    grid-template-columns: 1fr clamp(56px, 8vw, 96px) 1fr;
    align-items: center;
  }
  .job.left .job-card {
    grid-column: 1;
    text-align: left;
  }
  .job.right .job-card {
    grid-column: 3;
  }
  /* node sits on the spine, centred in the gutter column */
  .job-node {
    grid-column: 2;
    grid-row: 1;
    justify-self: center;
    z-index: 1;
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    color: var(--text-secondary);
    background: var(--bg);
    border: 1px solid var(--glass-border-strong);
    transition: color var(--dur-2) var(--ease-out), border-color var(--dur-2) var(--ease-out);
  }
  .job-node :global(svg) {
    width: 19px;
    height: 19px;
  }
  .job-node.now {
    background: var(--grad-brand);
    color: var(--accent-ink);
    border-color: transparent;
    box-shadow: 0 0 0 1px rgba(var(--accent-rgb), 0.28),
      0 8px 20px -8px rgba(var(--accent-rgb), 0.5);
  }
  .job:hover .job-node:not(.now) {
    color: var(--ink);
    border-color: var(--accent);
  }

  .job-card {
    padding: var(--card-pad);
    overflow: hidden;
  }
  .job-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .job-company {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: var(--fs-h3);
  }
  .job-company a {
    color: var(--text-tertiary);
    transition: color var(--dur-1) var(--ease-out), transform var(--dur-1) var(--ease-out);
  }
  .job-company a:hover {
    color: var(--accent);
    transform: translate(2px, -2px);
  }
  .job-role {
    margin-top: 2px;
    color: var(--accent);
    font-weight: 500;
    font-size: 0.98rem;
  }
  .job-period {
    font-size: var(--fs-xs);
    color: var(--text-tertiary);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }
  .job-body {
    margin-top: var(--sp-3);
    color: var(--text-secondary);
    line-height: 1.65;
  }
  .job-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-top: var(--sp-4);
  }

  .earlier {
    margin-top: var(--rail-pad);
    padding-top: var(--rail-pad);
    border-top: 1px solid var(--glass-border);
  }
  .earlier-label {
    font-size: var(--fs-xs);
    letter-spacing: 0.05em;
    color: var(--text-tertiary);
  }
  .earlier-grid {
    margin-top: 18px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(14px, 2vw, 24px);
  }
  .earlier-item {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .earlier-item strong {
    font-family: var(--font-display);
    font-size: 1.02rem;
  }
  .earlier-role {
    font-size: 0.85rem;
    color: var(--accent);
  }
  .earlier-note {
    font-size: 0.85rem;
    line-height: 1.45;
  }

  /* Collapse to a single left-aligned rail: spine moves to the left edge,
     every card sits to its right. This is also the reduced-motion layout
     (no dependency on JS or motion). */
  @media (max-width: 820px) {
    .timeline {
      gap: var(--grid-gap);
    }
    .spine {
      left: 21px;
    }
    .job {
      grid-template-columns: 44px 1fr;
      gap: var(--sp-4);
      align-items: start;
    }
    .job.left .job-card,
    .job.right .job-card {
      grid-column: 2;
      text-align: left;
    }
    .job-node {
      grid-column: 1;
      justify-self: start;
    }
    .earlier-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 420px) {
    .earlier-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
