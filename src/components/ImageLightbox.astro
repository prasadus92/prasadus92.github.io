---
/**
 * Delegated image lightbox for blog screenshots and diagrams.
 *
 * Add data-image-lightbox-trigger to a button or link, plus:
 * - data-image-lightbox-src
 * - data-image-lightbox-alt
 * - data-image-lightbox-caption
 */
---

<script>
  (() => {
    if ((window as any).__prasadImageLightboxInitialized) return;
    (window as any).__prasadImageLightboxInitialized = true;

    const OVERLAY_ID = 'image-lightbox';
    const OPEN_CLASS = 'image-lightbox-open';
    let lastFocused: HTMLElement | null = null;

    function clamp(value: number, min: number, max: number) {
      return Math.min(max, Math.max(min, value));
    }

    function triggerImage(trigger: Element) {
      if (trigger instanceof HTMLImageElement) return trigger;
      return trigger.querySelector<HTMLImageElement>('img');
    }

    function activeSrc(trigger: Element) {
      const image = triggerImage(trigger);
      if (image?.currentSrc && image.complete && image.naturalWidth > 0) return image.currentSrc;
      return trigger.getAttribute('data-image-lightbox-src') || image?.getAttribute('src');
    }

    function triggerAlt(trigger: Element) {
      const image = triggerImage(trigger);
      return trigger.getAttribute('data-image-lightbox-alt') || image?.alt || '';
    }

    function triggerCaption(trigger: Element) {
      const explicit = trigger.getAttribute('data-image-lightbox-caption');
      if (explicit) return explicit;
      const figure = trigger.closest('figure');
      return figure?.querySelector('figcaption')?.textContent?.trim() || '';
    }

    function isInlinePostImage(target: Element): target is HTMLImageElement {
      if (!(target instanceof HTMLImageElement)) return false;
      if (!target.closest('article.post-content')) return false;
      if (target.closest('.author-card, a, button, [data-image-lightbox-disabled], [data-image-lightbox-trigger]')) return false;
      return true;
    }

    function enhanceInlineImages() {
      const images = document.querySelectorAll<HTMLImageElement>('article.post-content img');
      images.forEach((image) => {
        if (!isInlinePostImage(image)) return;
        image.classList.add('post-image-inline-zoom');
        image.tabIndex = 0;
        image.setAttribute('role', 'button');
        image.setAttribute('aria-label', image.alt ? `Enlarge image: ${image.alt}` : 'Enlarge image');
      });
    }

    function closeViewer() {
      const overlay = document.getElementById(OVERLAY_ID);
      overlay?.remove();
      document.body.classList.remove(OPEN_CLASS);
      document.removeEventListener('keydown', onKeydown);
      lastFocused?.focus({ preventScroll: true });
      lastFocused = null;
    }

    function onKeydown(event: KeyboardEvent) {
      const overlay = document.getElementById(OVERLAY_ID);
      if (!overlay) return;

      if (event.key === 'Escape') {
        event.preventDefault();
        closeViewer();
        return;
      }

      const api = (overlay as any).__imageLightboxApi;
      if (!api) return;

      if (event.key === '+' || event.key === '=') {
        event.preventDefault();
        api.zoomBy(1.2);
      } else if (event.key === '-' || event.key === '_') {
        event.preventDefault();
        api.zoomBy(1 / 1.2);
      } else if (event.key === '0') {
        event.preventDefault();
        api.reset();
      }
    }

    function iconMarkup(name: string) {
      const attrs = 'viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"';
      if (name === 'zoom-in') return `<svg ${attrs}><path d="M11 5v12M5 11h12"/><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>`;
      if (name === 'zoom-out') return `<svg ${attrs}><path d="M5 11h12"/><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>`;
      if (name === 'reset') return `<svg ${attrs}><path d="M3 12a9 9 0 1 0 3-6.7"/><path d="M3 4v6h6"/></svg>`;
      return `<svg ${attrs}><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>`;
    }

    function iconButton(icon: string, ariaLabel: string) {
      const button = document.createElement('button');
      button.type = 'button';
      button.className = 'image-lightbox__button';
      button.innerHTML = iconMarkup(icon);
      button.setAttribute('aria-label', ariaLabel);
      button.title = ariaLabel;
      return button;
    }

    function openViewer(trigger: Element) {
      const src = activeSrc(trigger);
      if (!src) return;

      closeViewer();
      lastFocused = document.activeElement instanceof HTMLElement ? document.activeElement : null;

      const overlay = document.createElement('div');
      overlay.id = OVERLAY_ID;
      overlay.className = 'image-lightbox';
      overlay.setAttribute('role', 'dialog');
      overlay.setAttribute('aria-modal', 'true');
      overlay.setAttribute('aria-label', 'Expanded image');

      const toolbar = document.createElement('div');
      toolbar.className = 'image-lightbox__toolbar';

      const zoomOut = iconButton('zoom-out', 'Zoom out');
      const zoomLabel = document.createElement('span');
      zoomLabel.className = 'image-lightbox__zoom-label';
      zoomLabel.setAttribute('aria-live', 'polite');
      const zoomIn = iconButton('zoom-in', 'Zoom in');
      const reset = iconButton('reset', 'Reset zoom');
      const close = iconButton('close', 'Close image');
      close.classList.add('image-lightbox__close');
      toolbar.append(zoomOut, zoomLabel, zoomIn, reset, close);

      const viewport = document.createElement('div');
      viewport.className = 'image-lightbox__viewport';

      const stage = document.createElement('div');
      stage.className = 'image-lightbox__stage';

      const image = document.createElement('img');
      image.className = 'image-lightbox__image';
      image.src = src;
      image.alt = triggerAlt(trigger);
      image.decoding = 'async';
      image.draggable = false;
      stage.appendChild(image);
      viewport.appendChild(stage);

      const captionText = triggerCaption(trigger);
      if (captionText) {
        const caption = document.createElement('div');
        caption.className = 'image-lightbox__caption';
        caption.textContent = captionText;
        overlay.append(toolbar, viewport, caption);
      } else {
        overlay.append(toolbar, viewport);
      }

      document.body.appendChild(overlay);
      document.body.classList.add(OPEN_CLASS);

      let scale = 1;
      let tx = 0;
      let ty = 0;
      let dragging = false;
      let sx = 0;
      let sy = 0;
      let pinchStartDist = 0;
      let pinchStartScale = 1;
      const pointers = new Map<number, { x: number; y: number }>();

      function update() {
        scale = clamp(scale, 0.75, 7);
        stage.style.transform = `translate3d(${tx}px, ${ty}px, 0) scale(${scale})`;
        zoomLabel.textContent = `${Math.round(scale * 100)}%`;
      }

      function resetZoom() {
        scale = 1;
        tx = 0;
        ty = 0;
        update();
      }

      function zoomBy(factor: number) {
        scale = clamp(scale * factor, 0.75, 7);
        update();
      }

      function distance() {
        const values = Array.from(pointers.values());
        return Math.hypot(values[0].x - values[1].x, values[0].y - values[1].y);
      }

      zoomOut.addEventListener('click', () => zoomBy(1 / 1.2));
      zoomIn.addEventListener('click', () => zoomBy(1.2));
      reset.addEventListener('click', resetZoom);
      close.addEventListener('click', closeViewer);

      viewport.addEventListener('wheel', (event) => {
        event.preventDefault();
        zoomBy(event.deltaY < 0 ? 1.12 : 1 / 1.12);
      }, { passive: false });

      stage.addEventListener('pointerdown', (event) => {
        pointers.set(event.pointerId, { x: event.clientX, y: event.clientY });
        try { stage.setPointerCapture(event.pointerId); } catch (_) {}

        if (pointers.size === 1) {
          dragging = true;
          sx = event.clientX - tx;
          sy = event.clientY - ty;
        } else if (pointers.size === 2) {
          dragging = false;
          pinchStartDist = distance();
          pinchStartScale = scale;
        }
      });

      stage.addEventListener('pointermove', (event) => {
        if (!pointers.has(event.pointerId)) return;
        pointers.set(event.pointerId, { x: event.clientX, y: event.clientY });

        if (pointers.size >= 2 && pinchStartDist > 0) {
          scale = clamp(pinchStartScale * (distance() / pinchStartDist), 0.75, 7);
          update();
        } else if (dragging) {
          tx = event.clientX - sx;
          ty = event.clientY - sy;
          update();
        }
      });

      function release(event: PointerEvent) {
        pointers.delete(event.pointerId);
        if (pointers.size < 2) pinchStartDist = 0;
        if (pointers.size === 1) {
          const point = Array.from(pointers.values())[0];
          dragging = true;
          sx = point.x - tx;
          sy = point.y - ty;
        } else if (pointers.size === 0) {
          dragging = false;
        }
      }

      stage.addEventListener('pointerup', release);
      stage.addEventListener('pointercancel', release);
      stage.addEventListener('dblclick', () => {
        if (scale > 1.05) resetZoom();
        else zoomBy(2);
      });

      overlay.addEventListener('click', (event) => {
        if (event.target === overlay || event.target === viewport) closeViewer();
      });

      (overlay as any).__imageLightboxApi = { zoomBy, reset: resetZoom };
      document.addEventListener('keydown', onKeydown);
      update();
      close.focus({ preventScroll: true });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', enhanceInlineImages, { once: true });
    } else {
      enhanceInlineImages();
    }

    new MutationObserver(enhanceInlineImages).observe(document.body, {
      childList: true,
      subtree: true
    });

    document.addEventListener('click', (event) => {
      if (!(event.target instanceof Element)) return;
      const trigger = event.target.closest('[data-image-lightbox-trigger]');
      if (trigger) {
        event.preventDefault();
        openViewer(trigger);
        return;
      }

      if (isInlinePostImage(event.target)) {
        event.preventDefault();
        openViewer(event.target);
      }
    });

    document.addEventListener('keydown', (event) => {
      if (!(event.target instanceof Element)) return;
      if (event.key !== 'Enter' && event.key !== ' ') return;
      if (!isInlinePostImage(event.target)) return;
      event.preventDefault();
      openViewer(event.target);
    });
  })();
</script>
