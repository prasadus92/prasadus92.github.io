---
/**
 * Mermaid: client-side diagram renderer for blog posts.
 *
 * Loads Mermaid lazily so the rest of the page is unaffected. The diagram
 * source lives inline as the slot content. Theme follows the page theme
 * via data-theme on <html>. For static-by-default diagrams that do not need
 * Mermaid, prefer the native HTML/CSS visual blocks (visual-flow, swimlane,
 * visual-matrix) defined in global.css. They are faster, lighter, and
 * accessible without JavaScript.
 */

type Props = {
  caption?: string;
  ariaLabel?: string;
};

const { caption, ariaLabel } = Astro.props;
const id = `mermaid-${Math.random().toString(36).slice(2, 9)}`;
---
<figure class="mermaid-figure" data-mermaid-figure>
  <pre class="mermaid" id={id} aria-label={ariaLabel ?? caption ?? 'Diagram'}><slot /></pre>
  {caption && <figcaption class="post-visual-caption">{caption}</figcaption>}
</figure>

<script>
  const figures = document.querySelectorAll<HTMLElement>('[data-mermaid-figure]');
  if (figures.length > 0 && 'IntersectionObserver' in window) {
    const observer = new IntersectionObserver(async (entries, obs) => {
      const visible = entries.find((entry) => entry.isIntersecting);
      if (!visible) return;
      obs.disconnect();
      const { default: mermaid } = await import('mermaid');
      const isDark = document.documentElement.dataset.theme === 'dark';
      mermaid.initialize({
        startOnLoad: false,
        theme: isDark ? 'dark' : 'default',
        themeVariables: {
          fontFamily: 'Quicksand, ui-sans-serif, system-ui, sans-serif',
          fontSize: '14px'
        },
        securityLevel: 'strict'
      });
      mermaid.run({ querySelector: '.mermaid' });
    }, { threshold: 0.2 });
    figures.forEach((figure) => observer.observe(figure));
  }
</script>
