---
import { nav, site } from '../data/site';
import Icon from './Icon.astro';

const lastName = site.name.replace(site.shortName, '').trim();
---

<nav class="nav" id="nav">
  <div class="container nav-inner">
    <a href="/" class="brand" aria-label={`${site.name}, home`}>
      <span class="brand-mark">PS</span>
      <span class="brand-name">{site.shortName}<span class="brand-last"> {lastName}</span></span>
    </a>

    <ul class="nav-links" id="nav-links">
      {
        nav.map((item, i) => (
          <li style={`--i:${i}`}>
            <a href={item.href}>{item.label}</a>
          </li>
        ))
      }
      <li class="nav-mobile-extra" style={`--i:${nav.length}`}>
        <a href="/contact" class="btn btn-primary">Get in touch</a>
        <div class="nav-mobile-social">
          <a href={site.links.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn"
            ><Icon name="linkedin" size={20} /></a
          >
          <a href={site.links.github} target="_blank" rel="noopener" aria-label="GitHub"
            ><Icon name="github" size={20} /></a
          >
          <a href={`mailto:${site.email}`} aria-label="Email"><Icon name="mail" size={20} /></a>
        </div>
      </li>
    </ul>

    <div class="nav-actions">
      <a href="/contact" class="btn btn-primary nav-cta">Get in touch</a>
      <button class="icon-btn" id="theme-toggle" aria-label="Toggle theme">
        <span class="sun"><Icon name="sun" size={18} /></span>
        <span class="moon"><Icon name="moon" size={18} /></span>
      </button>
      <button class="nav-toggle" id="nav-toggle" aria-label="Menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: var(--z-nav);
    transition: background var(--dur-2) var(--ease-out), border-color var(--dur-2) var(--ease-out),
      backdrop-filter var(--dur-2) var(--ease-out);
    border-bottom: 1px solid transparent;
  }
  .nav.scrolled {
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    border-bottom-color: var(--glass-border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-weight: 600;
  }
  .brand-mark {
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: var(--r-md);
    font-size: 0.85rem;
    letter-spacing: 0.02em;
    color: var(--accent-ink);
    background: var(--grad-brand);
    box-shadow: var(--shadow-glow);
  }
  .brand-name {
    font-size: 1.02rem;
    letter-spacing: var(--tracking-snug);
    white-space: nowrap;
  }
  /* full name on larger screens; just the first name on small ones */
  @media (max-width: 560px) {
    .brand-last {
      display: none;
    }
  }
  .nav-links {
    display: flex;
    gap: clamp(8px, 2vw, 26px);
    list-style: none;
    padding: 0;
  }
  .nav-links a {
    position: relative;
    font-size: 0.94rem;
    color: var(--text-secondary);
    padding: 6px 2px;
    transition: color var(--dur-1) var(--ease-out);
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 0;
    height: 2px;
    border-radius: 2px;
    background: var(--grad-brand);
    transition: width var(--dur-2) var(--ease-out);
  }
  .nav-links a:hover,
  .nav-links a.active {
    color: var(--ink);
  }
  .nav-links a:hover::after,
  .nav-links a.active::after {
    width: 100%;
  }
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .icon-btn {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: var(--r-md);
    color: var(--text-secondary);
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    transition: color var(--dur-1) var(--ease-out), border-color var(--dur-1) var(--ease-out);
  }
  .icon-btn:hover {
    color: var(--ink);
    border-color: var(--glass-border-strong);
  }
  .icon-btn .moon {
    display: none;
  }
  .icon-btn[data-theme='light'] .sun {
    display: none;
  }
  .icon-btn[data-theme='light'] .moon {
    display: inline-flex;
  }
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    width: 38px;
    height: 38px;
    align-items: center;
    justify-content: center;
  }
  .nav-toggle span {
    width: 20px;
    height: 2px;
    border-radius: 2px;
    background: var(--ink);
    transition: transform var(--dur-2) var(--ease-out), opacity var(--dur-1) var(--ease-out);
  }
  .nav-toggle.open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-toggle.open span:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle.open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .nav-mobile-extra {
    display: none;
  }

  @media (max-width: 860px) {
    .nav-cta {
      display: none;
    }
    .nav-toggle {
      display: flex;
    }
    /* Full-screen premium overlay */
    .nav-links {
      position: fixed;
      inset: 0;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 6px;
      padding: 88px var(--gutter) 48px;
      margin: 0;
      background: color-mix(in srgb, var(--bg) 88%, transparent);
      backdrop-filter: blur(28px) saturate(140%);
      -webkit-backdrop-filter: blur(28px) saturate(140%);
      opacity: 0;
      pointer-events: none;
      transition: opacity var(--dur-2) var(--ease-out);
    }
    .nav-links.open {
      opacity: 1;
      pointer-events: auto;
    }
    .nav-links li {
      opacity: 0;
      transform: translateY(12px);
      transition: opacity var(--dur-2) var(--ease-out), transform var(--dur-2) var(--ease-out);
    }
    .nav-links.open li {
      opacity: 1;
      transform: none;
      transition-delay: calc(0.05s * var(--i) + 0.08s);
    }
    .nav-links a {
      font-family: var(--font-display);
      font-size: 1.6rem;
      font-weight: 500;
      padding: 12px 4px;
    }
    .nav-links a::after {
      display: none;
    }
    .nav-mobile-extra {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 22px;
      margin-top: 28px;
    }
    .nav-mobile-extra .btn {
      font-size: 1rem;
      padding: 0.9em 1.8em;
    }
    .nav-mobile-social {
      display: flex;
      gap: 10px;
    }
    .nav-mobile-social a {
      display: grid;
      place-items: center;
      width: 46px;
      height: 46px;
      border-radius: var(--r-md);
      color: var(--text-secondary);
      border: 1px solid var(--glass-border);
      background: var(--glass-bg);
      transition: color var(--dur-1) var(--ease-out), border-color var(--dur-1) var(--ease-out);
    }
    .nav-mobile-social a:hover {
      color: var(--accent);
      border-color: var(--glass-border-strong);
    }
  }

  /* lock scroll when menu open */
  :global(body.nav-open) {
    overflow: hidden;
  }
</style>
