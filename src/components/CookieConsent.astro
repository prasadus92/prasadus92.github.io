---
// Cookie consent banner. Writes the choice to localStorage and dispatches
// `prasad:consent-changed`, which Analytics.astro listens for. Styled to match
// the site (glass surface, accent button, 2px radius).
const CONSENT_KEY = 'prasad-consent-v1';
---

<div class="cookie glass" id="cookie-consent" role="dialog" aria-label="Cookie preferences" hidden>
  <p class="cookie-copy" id="cookie-copy">
    I use analytics to see which pages are useful. Nothing else. You can decline.
    <a href="/privacy/">Privacy</a>
  </p>
  <div class="cookie-actions">
    <button class="btn btn-ghost cookie-btn" type="button" data-cookie-reject>Decline</button>
    <button class="btn btn-primary cookie-btn" type="button" data-cookie-accept>Accept</button>
  </div>
</div>

<script is:inline define:vars={{ CONSENT_KEY }}>
  (function () {
    function readConsent() {
      try {
        var raw = localStorage.getItem(CONSENT_KEY);
        if (!raw) return null;
        var parsed = JSON.parse(raw);
        return parsed && parsed.version === 1 ? parsed : null;
      } catch (e) {
        return null;
      }
    }
    function writeConsent(analytics) {
      var payload = { analytics: !!analytics, timestamp: Date.now(), version: 1 };
      try {
        localStorage.setItem(CONSENT_KEY, JSON.stringify(payload));
      } catch (e) {}
      window.PrasadConsent = payload;
      try {
        window.dispatchEvent(new CustomEvent('prasad:consent-changed', { detail: payload }));
      } catch (e) {}
    }
    var banner = document.getElementById('cookie-consent');
    if (banner && !readConsent()) {
      banner.hidden = false;
      requestAnimationFrame(function () {
        banner.classList.add('in');
      });
    }
    function decide(analytics) {
      writeConsent(analytics);
      if (banner) {
        banner.classList.remove('in');
        setTimeout(function () {
          banner.hidden = true;
        }, 300);
      }
    }
    var accept = banner && banner.querySelector('[data-cookie-accept]');
    var reject = banner && banner.querySelector('[data-cookie-reject]');
    if (accept) accept.addEventListener('click', function () { decide(true); });
    if (reject) reject.addEventListener('click', function () { decide(false); });
  })();
</script>

<style>
  .cookie {
    position: fixed;
    left: clamp(16px, 4vw, 28px);
    right: clamp(16px, 4vw, 28px);
    bottom: clamp(16px, 4vw, 28px);
    max-width: 440px;
    margin-left: auto;
    z-index: var(--z-overlay);
    padding: var(--sp-4) var(--sp-5);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    opacity: 0;
    transform: translateY(12px);
    transition: opacity var(--dur-2) var(--ease-out), transform var(--dur-2) var(--ease-out);
  }
  .cookie.in {
    opacity: 1;
    transform: none;
  }
  .cookie-copy {
    font-size: var(--fs-sm);
    line-height: 1.55;
    color: var(--text-secondary);
  }
  .cookie-copy a {
    color: var(--accent);
    white-space: nowrap;
  }
  .cookie-actions {
    display: flex;
    gap: var(--sp-2);
    justify-content: flex-end;
  }
  .cookie-btn {
    padding: 0.6em 1.1em;
    font-size: var(--fs-sm);
  }
  @media (prefers-reduced-motion: reduce) {
    .cookie {
      transition: none;
    }
  }
</style>
