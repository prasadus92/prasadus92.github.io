---
const CONSENT_KEY = 'prasad-consent-v1';
---

<div
  class="cookie-consent"
  id="cookie-consent"
  role="dialog"
  aria-label="Cookie preferences"
  aria-describedby="cookie-consent-copy"
  hidden
>
  <div class="cookie-consent-card">
    <div class="cookie-consent-copy">
      <div class="footer-kicker">Cookies</div>
      <h2>Analytics, only with permission</h2>
      <p id="cookie-consent-copy">
        I use analytics to learn which pages are useful. Essential preferences stay on.
      </p>
    </div>
    <div class="cookie-consent-actions">
      <button class="button primary" type="button" data-cookie-accept>Accept analytics</button>
      <button class="button" type="button" data-cookie-reject>Reject</button>
    </div>
    <a class="cookie-privacy-link" href="/privacy/">Privacy</a>
  </div>
</div>

<script is:inline define:vars={{ CONSENT_KEY }}>
  (function () {
    function readConsent() {
      try {
        var raw = localStorage.getItem(CONSENT_KEY);
        if (!raw) return null;
        var parsed = JSON.parse(raw);
        return parsed && parsed.version === 1 ? parsed : null;
      } catch (e) {
        return null;
      }
    }

    function writeConsent(analytics) {
      var payload = { analytics: !!analytics, timestamp: Date.now(), version: 1 };
      try {
        localStorage.setItem(CONSENT_KEY, JSON.stringify(payload));
      } catch (e) {}
      window.PrasadConsent = payload;
      try {
        window.dispatchEvent(new CustomEvent('prasad:consent-changed', { detail: payload }));
      } catch (e) {}
      return payload;
    }

    function bindConsent() {
      var banner = document.getElementById('cookie-consent');
      if (!banner) return;

      var existing = readConsent();
      if (existing) {
        window.PrasadConsent = existing;
        banner.hidden = true;
      } else {
        banner.hidden = false;
      }

      var accept = banner.querySelector('[data-cookie-accept]');
      var reject = banner.querySelector('[data-cookie-reject]');
      if (accept && !accept.dataset.bound) {
        accept.dataset.bound = 'true';
        accept.addEventListener('click', function () {
          writeConsent(true);
          banner.hidden = true;
        });
      }
      if (reject && !reject.dataset.bound) {
        reject.dataset.bound = 'true';
        reject.addEventListener('click', function () {
          writeConsent(false);
          banner.hidden = true;
        });
      }

      document.querySelectorAll('[data-open-cookie-settings]').forEach(function (trigger) {
        if (trigger.dataset.bound) return;
        trigger.dataset.bound = 'true';
        trigger.addEventListener('click', function () {
          banner.hidden = false;
        });
      });
    }

    bindConsent();
  })();
</script>
