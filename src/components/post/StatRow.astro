---
type Stat = {
  value: string;
  label: string;
  caption?: string;
};

type Props = {
  stats: Stat[];
};

const { stats } = Astro.props;
---
<div class="stat-row reveal">
  {stats.map((stat) => (
    <div class="stat-row-item card">
      <strong class="stat-row-value">{stat.value}</strong>
      <span class="stat-row-label">{stat.label}</span>
      {stat.caption && <p class="stat-row-caption">{stat.caption}</p>}
    </div>
  ))}
</div>
