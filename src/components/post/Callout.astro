---
type Tone = 'info' | 'note' | 'warning' | 'success';

type Props = {
  tone?: Tone;
  title?: string;
};

const { tone = 'note', title } = Astro.props;
---
<aside class={`callout callout-${tone} reveal`} role="note">
  <div class="callout-mark" aria-hidden="true"></div>
  <div class="callout-body">
    {title && <p class="callout-title">{title}</p>}
    <slot />
  </div>
</aside>
