---
type Props = {
  name: string;
  role: string;
  trigger: string;
  reads?: string;
  writes?: string;
  guardrail?: string;
  cadence?: string;
};

const { name, role, trigger, reads, writes, guardrail, cadence } = Astro.props;
---
<article class="role-card card reveal">
  <header class="role-card-head">
    <h3 class="role-card-name">{name}</h3>
    <p class="role-card-role">{role}</p>
  </header>
  <dl class="role-card-meta">
    <div>
      <dt>Trigger</dt>
      <dd>{trigger}</dd>
    </div>
    {cadence && (
      <div>
        <dt>Cadence</dt>
        <dd>{cadence}</dd>
      </div>
    )}
    {reads && (
      <div>
        <dt>Reads</dt>
        <dd>{reads}</dd>
      </div>
    )}
    {writes && (
      <div>
        <dt>Writes</dt>
        <dd>{writes}</dd>
      </div>
    )}
    {guardrail && (
      <div>
        <dt>Guardrail</dt>
        <dd>{guardrail}</dd>
      </div>
    )}
  </dl>
  <div class="role-card-body">
    <slot />
  </div>
</article>
