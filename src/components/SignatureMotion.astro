---
/*
  SignatureMotion — a pointer-reactive constellation field rendered on a single
  <canvas>. Geometric "shards" assemble on load and drift gently, connected by
  thin gradient lines that brighten near the pointer. Sits behind the hero
  content as atmosphere; theme-aware via CSS custom props read at runtime.

  Performance contract:
  - one <canvas>, one requestAnimationFrame loop
  - particle count capped (<= ~64, scaled down on small screens)
  - devicePixelRatio clamped to 2
  - loop paused when tab hidden (visibilitychange) and when offscreen
    (IntersectionObserver)
  - frame budget throttled to ~40fps
  - prefers-reduced-motion: renders a single static frame, no loop
*/
---

<div class="sig-motion" aria-hidden="true" data-sig-motion>
  <canvas class="sig-canvas" data-sig-canvas></canvas>
</div>

<style>
  .sig-motion {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
    /* tokens read by the script via getComputedStyle */
    --sig-accent: var(--accent);
    --sig-accent-2: var(--accent-2);
    /* fade the field out toward the bottom so it never fights body copy */
    -webkit-mask-image: radial-gradient(120% 95% at 70% 28%, #000 38%, transparent 92%);
    mask-image: radial-gradient(120% 95% at 70% 28%, #000 38%, transparent 92%);
  }
  .sig-canvas {
    display: block;
    width: 100%;
    height: 100%;
    opacity: 0.9;
  }
  [data-theme='light'] .sig-canvas {
    opacity: 0.62;
  }
</style>

<script>
  type RGB = [number, number, number];

  interface Node {
    x: number;
    y: number;
    // home (drift origin) + slow velocity
    hx: number;
    hy: number;
    vx: number;
    vy: number;
    // assemble animation: start offset + delay
    sx: number;
    sy: number;
    delay: number;
    r: number;
    rot: number;
    vrot: number;
    sides: number; // 0 = dot, 3/4/6 = shard
    tone: number; // 0..1 mix between accent and accent-2
  }

  function parseColor(raw: string): RGB {
    const s = raw.trim();
    const hex = s.match(/^#([0-9a-f]{3}|[0-9a-f]{6})$/i);
    if (hex) {
      let h = hex[1];
      if (h.length === 3) h = h.split('').map((c) => c + c).join('');
      return [
        parseInt(h.slice(0, 2), 16),
        parseInt(h.slice(2, 4), 16),
        parseInt(h.slice(4, 6), 16),
      ];
    }
    const m = s.match(/(-?\d+\.?\d*)/g);
    if (m && m.length >= 3) return [+m[0], +m[1], +m[2]];
    return [246, 62, 140];
  }

  function initSignatureMotion() {
    const root = document.querySelector<HTMLElement>('[data-sig-motion]');
    const canvas = document.querySelector<HTMLCanvasElement>('[data-sig-canvas]');
    if (!root || !canvas) return;
    const ctx = canvas.getContext('2d', { alpha: true });
    if (!ctx) return;

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const finePointer = window.matchMedia('(pointer: fine)').matches;

    let W = 0;
    let H = 0;
    let dpr = 1;
    let nodes: Node[] = [];
    let accent: RGB = [246, 62, 140];
    let accent2: RGB = [124, 108, 255];

    // pointer (in CSS px, smoothed)
    let pxTarget = -9999;
    let pyTarget = -9999;
    let px = -9999;
    let py = -9999;
    const LINK_DIST = 132; // px, connect nodes within this range
    const POINTER_R = 200; // px, pointer influence radius

    const readColors = () => {
      const cs = getComputedStyle(root);
      accent = parseColor(cs.getPropertyValue('--sig-accent') || '#f63e8c');
      accent2 = parseColor(cs.getPropertyValue('--sig-accent-2') || '#7c6cff');
    };

    const count = () => {
      const area = W * H;
      // ~1 node per 13k css px², capped well under 80
      const n = Math.round(area / 13000);
      return Math.max(18, Math.min(64, n));
    };

    const makeNodes = () => {
      const n = count();
      nodes = [];
      for (let i = 0; i < n; i++) {
        const x = Math.random() * W;
        const y = Math.random() * H;
        const sidesRoll = Math.random();
        const sides = sidesRoll > 0.82 ? (Math.random() > 0.5 ? 4 : 3) : 0;
        nodes.push({
          x,
          y,
          hx: x,
          hy: y,
          vx: (Math.random() - 0.5) * 0.12,
          vy: (Math.random() - 0.5) * 0.12,
          sx: x + (Math.random() - 0.5) * W * 0.5,
          sy: y + (Math.random() - 0.5) * H * 0.5,
          delay: Math.random() * 0.55,
          r: sides ? 2.6 + Math.random() * 3.4 : 1 + Math.random() * 1.6,
          rot: Math.random() * Math.PI,
          vrot: (Math.random() - 0.5) * 0.006,
          sides,
          tone: Math.random(),
        });
      }
    };

    const resize = () => {
      const rect = root.getBoundingClientRect();
      W = Math.max(1, rect.width);
      H = Math.max(1, rect.height);
      dpr = Math.min(2, window.devicePixelRatio || 1);
      canvas.width = Math.round(W * dpr);
      canvas.height = Math.round(H * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      makeNodes();
    };

    const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

    const drawShape = (nd: Node, alpha: number, color: RGB) => {
      ctx.save();
      ctx.translate(nd.x, nd.y);
      if (nd.sides) {
        ctx.rotate(nd.rot);
        ctx.beginPath();
        for (let i = 0; i < nd.sides; i++) {
          const a = (i / nd.sides) * Math.PI * 2 - Math.PI / 2;
          const vx = Math.cos(a) * nd.r;
          const vy = Math.sin(a) * nd.r;
          i === 0 ? ctx.moveTo(vx, vy) : ctx.lineTo(vx, vy);
        }
        ctx.closePath();
        ctx.fillStyle = `rgba(${color[0]},${color[1]},${color[2]},${alpha * 0.5})`;
        ctx.fill();
        ctx.lineWidth = 1;
        ctx.strokeStyle = `rgba(${color[0]},${color[1]},${color[2]},${alpha})`;
        ctx.stroke();
      } else {
        ctx.beginPath();
        ctx.arc(0, 0, nd.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${color[0]},${color[1]},${color[2]},${alpha})`;
        ctx.fill();
      }
      ctx.restore();
    };

    // assemble progress 0..1, eased
    let assemble = 0;
    let startTime = 0;

    const render = (time: number) => {
      if (!startTime) startTime = time;
      const elapsed = (time - startTime) / 1000;
      // ~1.1s assemble
      assemble = Math.min(1, elapsed / 1.1);

      // smooth pointer
      px = px < -9000 ? pxTarget : lerp(px, pxTarget, 0.12);
      py = py < -9000 ? pyTarget : lerp(py, pyTarget, 0.12);

      ctx.clearRect(0, 0, W, H);

      for (const nd of nodes) {
        // drift home
        if (assemble >= 1) {
          nd.hx += nd.vx;
          nd.hy += nd.vy;
          if (nd.hx < -20 || nd.hx > W + 20) nd.vx *= -1;
          if (nd.hy < -20 || nd.hy > H + 20) nd.vy *= -1;
          nd.rot += nd.vrot;
        }

        // assemble: ease shards from scatter -> home, staggered by delay
        const local = Math.max(0, Math.min(1, (assemble - nd.delay) / (1 - nd.delay)));
        const e = 1 - Math.pow(1 - local, 3); // easeOutCubic
        let tx = lerp(nd.sx, nd.hx, e);
        let ty = lerp(nd.sy, nd.hy, e);

        // pointer parallax + gentle repulsion
        if (finePointer && px > -9000) {
          const dx = tx - px;
          const dy = ty - py;
          const d = Math.hypot(dx, dy);
          if (d < POINTER_R && d > 0.01) {
            const f = (1 - d / POINTER_R) * 14;
            tx += (dx / d) * f;
            ty += (dy / d) * f;
          }
        }
        nd.x = tx;
        nd.y = ty;
      }

      // connecting lines
      const dist2 = LINK_DIST * LINK_DIST;
      for (let i = 0; i < nodes.length; i++) {
        const a = nodes[i];
        for (let j = i + 1; j < nodes.length; j++) {
          const b = nodes[j];
          const dx = a.x - b.x;
          const dy = a.y - b.y;
          const d2 = dx * dx + dy * dy;
          if (d2 > dist2) continue;
          const d = Math.sqrt(d2);
          let alpha = (1 - d / LINK_DIST) * 0.38 * assemble;
          // brighten links near the pointer
          if (finePointer && px > -9000) {
            const mx = (a.x + b.x) / 2;
            const my = (a.y + b.y) / 2;
            const pd = Math.hypot(mx - px, my - py);
            if (pd < POINTER_R) alpha += (1 - pd / POINTER_R) * 0.4;
          }
          if (alpha <= 0.01) continue;
          const t = (a.tone + b.tone) / 2;
          const c: RGB = [
            Math.round(lerp(accent[0], accent2[0], t)),
            Math.round(lerp(accent[1], accent2[1], t)),
            Math.round(lerp(accent[2], accent2[2], t)),
          ];
          ctx.strokeStyle = `rgba(${c[0]},${c[1]},${c[2]},${Math.min(0.85, alpha)})`;
          ctx.lineWidth = 1;
          ctx.beginPath();
          ctx.moveTo(a.x, a.y);
          ctx.lineTo(b.x, b.y);
          ctx.stroke();
        }
      }

      // nodes
      for (const nd of nodes) {
        const c: RGB = [
          Math.round(lerp(accent[0], accent2[0], nd.tone)),
          Math.round(lerp(accent[1], accent2[1], nd.tone)),
          Math.round(lerp(accent[2], accent2[2], nd.tone)),
        ];
        let a = (nd.sides ? 0.85 : 0.7) * assemble;
        if (finePointer && px > -9000) {
          const pd = Math.hypot(nd.x - px, nd.y - py);
          if (pd < POINTER_R) a = Math.min(1, a + (1 - pd / POINTER_R) * 0.35);
        }
        drawShape(nd, a, c);
      }
    };

    // ---- static frame for reduced motion ----
    const renderStatic = () => {
      assemble = 1;
      for (const nd of nodes) {
        nd.x = nd.hx;
        nd.y = nd.hy;
      }
      px = -9999;
      py = -9999;
      render(performance.now());
    };

    // ---- loop with frame budget + gating ----
    let raf = 0;
    let running = false;
    let visible = true;
    let onScreen = true;
    let last = 0;
    const FRAME_MS = 1000 / 40;

    const loop = (time: number) => {
      raf = requestAnimationFrame(loop);
      if (time - last < FRAME_MS) return;
      last = time;
      render(time);
    };

    const start = () => {
      if (running || reduce) return;
      if (!visible || !onScreen) return;
      running = true;
      last = 0;
      raf = requestAnimationFrame(loop);
    };
    const stop = () => {
      running = false;
      if (raf) cancelAnimationFrame(raf);
      raf = 0;
    };

    // ---- wiring ----
    readColors();
    resize();

    if (reduce) {
      renderStatic();
    } else {
      // re-read theme colors when it flips (no-flash script toggles data-theme)
      const themeObs = new MutationObserver(() => {
        readColors();
        if (!running) render(performance.now());
      });
      themeObs.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['data-theme'],
      });

      let resizeTimer = 0;
      window.addEventListener(
        'resize',
        () => {
          window.clearTimeout(resizeTimer);
          resizeTimer = window.setTimeout(() => {
            startTime = 0; // replay assemble after a resize-driven rebuild
            resize();
          }, 180);
        },
        { passive: true }
      );

      if (finePointer) {
        window.addEventListener(
          'pointermove',
          (e) => {
            const rect = root.getBoundingClientRect();
            pxTarget = e.clientX - rect.left;
            pyTarget = e.clientY - rect.top;
          },
          { passive: true }
        );
        window.addEventListener(
          'pointerleave',
          () => {
            pxTarget = -9999;
            pyTarget = -9999;
          },
          { passive: true }
        );
      }

      document.addEventListener('visibilitychange', () => {
        visible = !document.hidden;
        visible ? start() : stop();
      });

      const io = new IntersectionObserver(
        (entries) => {
          onScreen = entries[0]?.isIntersecting ?? true;
          onScreen ? start() : stop();
        },
        { threshold: 0 }
      );
      io.observe(root);

      start();
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSignatureMotion);
  } else {
    initSignatureMotion();
  }
</script>
